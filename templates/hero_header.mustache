{{!
    @template local_dimensions/hero_header

    Hero Header template for competency display.

    Context variables required:
    * title (string) - The competency shortname (formatted)
    * description (string) - The competency description (formatted HTML)
    * hasdescription (bool) - Whether description exists
    * bgcolor (string) - Custom background color in hex format (optional)
    * hasbgcolor (bool) - Whether custom bgcolor exists
    * textcolor (string) - Custom text color in hex format (optional)
    * hastextcolor (bool) - Whether custom textcolor exists
    * duedate (string) - Formatted due date (optional)
    * hasduedate (bool) - Whether due date exists

    Example context (json):
    {
        "title": "Communication Skills",
        "description": "<p>Develop effective communication...</p>",
        "hasdescription": true,
        "bgcolor": "#3498db",
        "hasbgcolor": true,
        "textcolor": "#ffffff",
        "hastextcolor": true,
        "duedate": "31 Jan 2026",
        "hasduedate": true
    }
}}
<div class="dims-hero-wrapper {{#hasbgimage}}dims-hero-has-image{{/hasbgimage}}" id="dimensions-hero"
     {{#hasbgimage}}style="--hero-bg-image: url('{{bgimage}}'); {{#hasbgcolor}}--hero-overlay-color: {{bgcolor}};{{/hasbgcolor}}"{{/hasbgimage}}>
    <div class="dims-hero {{^hasbgcolor}}{{^hasbgimage}}bg-primary{{/hasbgimage}}{{/hasbgcolor}}" 
         style="{{#hasbgcolor}}background-color: var(--dimension-custombgcolor);{{/hasbgcolor}}{{#hastextcolor}} color: var(--dimension-customtextcolor);{{/hastextcolor}}">
        <div class="dims-hero-content">
            <h1 class="dims-hero-title">{{{title}}}</h1>
            {{#hasdescription}}
                <div class="dims-hero-description">
                    {{{description}}}
                </div>
            {{/hasdescription}}
            {{#hasduedate}}
            <div class="dims-duedate-card">
                <img class="dims-duedate-icon" src="{{duedateiconurl}}" alt="" aria-hidden="true">
                <div class="dims-duedate-content">
                    <span class="dims-duedate-label">{{#str}}duedate, local_dimensions{{/str}}</span>
                    <span class="dims-duedate-value">{{duedate}}</span>
                </div>
            </div>
            {{/hasduedate}}
        </div>
    </div>
</div>
