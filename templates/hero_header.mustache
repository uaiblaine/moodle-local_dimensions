{{!
    @template local_dimensions/hero_header

    Hero Header template for competency display.

    Context variables required:
    * title (string) - The competency shortname (formatted)
    * description (string) - The competency description (formatted HTML)
    * hasdescription (bool) - Whether description exists
    * bgcolor (string) - Custom background color in hex format (optional)
    * hasbgcolor (bool) - Whether custom bgcolor exists
    * textcolor (string) - Custom text color in hex format (optional)
    * hastextcolor (bool) - Whether custom textcolor exists
    * duedate (string) - Formatted due date (optional)
    * hasduedate (bool) - Whether due date exists

    Example context (json):
    {
        "title": "Communication Skills",
        "description": "<p>Develop effective communication...</p>",
        "hasdescription": true,
        "bgcolor": "#3498db",
        "hasbgcolor": true,
        "textcolor": "#ffffff",
        "hastextcolor": true,
        "duedate": "31 Jan 2026",
        "hasduedate": true
    }

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="local-dimensions-hero-wrapper {{#hasbgimage}}local-dimensions-hero-has-image{{/hasbgimage}}" id="local-dimensions-hero"
     {{#hasbgimage}}style="--hero-bg-image: url('{{bgimage}}'); {{#hasbgcolor}}--hero-overlay-color: {{bgcolor}};{{/hasbgcolor}}"{{/hasbgimage}}>
    <div class="local-dimensions-hero {{^hasbgcolor}}{{^hasbgimage}}bg-primary{{/hasbgimage}}{{/hasbgcolor}}" 
         style="{{#hasbgcolor}}background-color: var(--dimension-custombgcolor);{{/hasbgcolor}}{{#hastextcolor}} color: var(--dimension-customtextcolor);{{/hastextcolor}}">
        <div class="local-dimensions-hero-content">
            <h1 class="local-dimensions-hero-title">{{{title}}}</h1>
            {{#hasdescription}}
                <div class="local-dimensions-hero-description">
                    {{{description}}}
                </div>
            {{/hasdescription}}
            {{#hasduedate}}
            <div class="local-dimensions-duedate-card">
                <img class="local-dimensions-duedate-icon" src="{{duedateiconurl}}" alt="" aria-hidden="true">
                <div class="local-dimensions-duedate-content">
                    <span class="local-dimensions-duedate-label">{{#str}}duedate, local_dimensions{{/str}}</span>
                    <span class="local-dimensions-duedate-value">{{duedate}}</span>
                </div>
            </div>
            {{/hasduedate}}
        </div>
    </div>
</div>
