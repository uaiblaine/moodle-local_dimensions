{{!
    @template local_dimensions/central/enrol_row

    One course row of the Enrolment methods accordion. The row's data attributes carry both
    methods' status and configured-since dates so local_dimensions/central/enrol_methods can
    repaint the status pill when the method segment changes and feed the details modal without
    another request. The pill and the checkbox/spinner swap are painted client-side after render.

    Context variables required:
    * courseid (int) · shortname · fullname · categoryname (strings) · visible (bool)
    * courseurl · cohortstatus · selfstatus · cohortconfiguredsince · selfconfiguredsince (strings)
    * competencyname · selectlabel · infolabel (strings)

    Example context (json):
    {
        "courseid": 42,
        "shortname": "MKT-101",
        "fullname": "Communication fundamentals",
        "categoryname": "Marketing",
        "visible": true,
        "courseurl": "https://example.com/course/view.php?id=42",
        "cohortstatus": "configured",
        "selfstatus": "notconfigured",
        "cohortconfiguredsince": "3 July 2026",
        "selfconfiguredsince": "",
        "competencyname": "Corporate communication",
        "selectlabel": "Select MKT-101",
        "infolabel": "Details"
    }
}}
<div class="local-dimensions-enrol-row d-flex align-items-center gap-2 py-1" data-courseid="{{courseid}}"
     data-cohort-status="{{cohortstatus}}" data-self-status="{{selfstatus}}"
     data-cohort-since="{{cohortconfiguredsince}}" data-self-since="{{selfconfiguredsince}}"
     data-courseurl="{{courseurl}}" data-visible="{{#visible}}1{{/visible}}{{^visible}}0{{/visible}}"
     data-shortname="{{shortname}}" data-fullname="{{fullname}}" data-categoryname="{{categoryname}}"
     data-competencyname="{{competencyname}}">
    <input type="checkbox" class="form-check-input m-0" data-rowcheck aria-label="{{selectlabel}}">
    <i class="fa fa-spinner fa-spin text-primary" aria-hidden="true" data-region="row-spinner" hidden></i>
    <span class="text-truncate flex-grow-1">
        <span class="fw-medium">{{shortname}}</span> · {{fullname}}
        {{^visible}}<i class="fa fa-eye-slash text-muted ms-1" aria-hidden="true"></i>{{/visible}}
    </span>
    <span class="badge bg-secondary">{{categoryname}}</span>
    <span class="badge" data-region="row-status"></span>
    <button type="button" class="btn btn-outline-secondary btn-sm" data-action="enrol-info">
        <i class="fa fa-circle-info me-1" aria-hidden="true"></i>{{infolabel}}
    </button>
</div>
