{{!
    @template local_dimensions/central/plans

    Learning plans tab: template list + the selected template's competencies (cross-framework).

    The System / Course category context selector is rendered once at page level
    (local_dimensions/central/contextbar); this tab receives the resolved context via its
    data attributes and shows the guided empty state when a category is still needed.

    Context variables required:
    * contexttype (string) · selectedcategoryid (int) · contextid (int) · needscategoryselection (bool)
    * hastemplates (bool) · templates (array) {id, name, competencycount, visible, selected}
    * selectedtemplateid (int) · selectedtemplatename (string) · selectedtemplateplancount (int)
    * hascompetencies (bool) · competencies (array) {id, shortname, frameworktag, first, last}
    * excludeids (string) · comma-separated ids already on the template (add-picker exclusion)
    * competencycount (int) · canmanage (int) · canassignroles (int)
    * competencyid (int) · filteredbycompetency (bool)
    * selectedcompetencyid (int) · selectedcompetencylabel (string)

    Example context (json):
    {
        "contexttype": "system",
        "selectedcategoryid": 0,
        "contextid": 1,
        "needscategoryselection": false,
        "competencyid": 7,
        "filteredbycompetency": true,
        "selectedcompetencyid": 7,
        "selectedcompetencylabel": "Communication · CORE",
        "hastemplates": true,
        "templates": [
            {"id": 4, "name": "Induction plan", "competencycount": 6, "visible": true, "selected": true}
        ],
        "selectedtemplateid": 4,
        "selectedtemplatename": "Induction plan",
        "selectedtemplateplancount": 12,
        "hascompetencies": true,
        "excludeids": "7,9",
        "competencies": [
            {"id": 7, "shortname": "Communication", "frameworktag": "CORE", "first": true, "last": false},
            {"id": 9, "shortname": "Teamwork", "frameworktag": "SOFT", "first": false, "last": true}
        ],
        "competencycount": 6,
        "canmanage": 1,
        "canassignroles": 1
    }
}}
<div class="local-dimensions-central-plans" data-region="plans"
     data-contexttype="{{contexttype}}" data-categoryid="{{selectedcategoryid}}"
     data-contextid="{{contextid}}" data-templateid="{{selectedtemplateid}}"
     data-templatename="{{selectedtemplatename}}" data-canassignroles="{{canassignroles}}">
    {{#needscategoryselection}}
    <div class="alert alert-info" role="status">{{#str}}managecompetencies_selectcategory_help, local_dimensions{{/str}}</div>
    {{/needscategoryselection}}

    {{^needscategoryselection}}
    <div class="d-flex flex-wrap align-items-end gap-3 mb-3" data-region="plan-search">
        <div class="flex-grow-1">
            <label class="d-block small text-muted mb-1" for="local-dimensions-central-competency-search">
                {{#str}}central_searchcompetency, local_dimensions{{/str}}
            </label>
            <select id="local-dimensions-central-competency-search" data-region="competency-search" class="form-select">
                {{#filteredbycompetency}}
                <option value="{{selectedcompetencyid}}" selected>{{selectedcompetencylabel}}</option>
                {{/filteredbycompetency}}
            </select>
        </div>
        {{#canmanage}}
        <div class="ms-auto align-self-center">
            <button type="button" class="btn btn-primary btn-sm" data-action="new-template">
                <i class="fa fa-plus me-1" aria-hidden="true"></i>{{#str}}managetemplates_addtemplate, local_dimensions{{/str}}
            </button>
        </div>
        {{/canmanage}}
        {{#filteredbycompetency}}
        <div class="align-self-center">
            <span class="badge bg-info text-dark">{{#str}}central_filteredbycompetency, local_dimensions, {{selectedcompetencylabel}}{{/str}}</span>
            <button type="button" class="btn btn-sm btn-link" data-action="clear-competency">
                {{#str}}central_clearcompetencyfilter, local_dimensions{{/str}}
            </button>
        </div>
        {{/filteredbycompetency}}
    </div>
    {{#hastemplates}}
    <div class="row">
        <section class="col-lg-5 mb-3" data-region="template-list">
            <div class="card h-100">
                <div class="card-body p-2">
                    {{#templates}}
                    <button type="button"
                            class="btn btn-link text-start text-decoration-none d-flex align-items-center w-100 px-2 py-1 local-dimensions-central-row {{#selected}}active{{/selected}}"
                            data-action="select-template" data-id="{{id}}">
                        <i class="fa fa-clipboard-list me-2 text-muted" aria-hidden="true"></i>
                        <span class="flex-grow-1">{{name}}</span>
                        <span class="badge bg-light text-muted">{{competencycount}}</span>
                        {{^visible}}<span class="badge bg-secondary ms-1">{{#str}}hidden, tool_lp{{/str}}</span>{{/visible}}
                    </button>
                    {{/templates}}
                </div>
            </div>
        </section>

        <aside class="col-lg-7 mb-3" data-region="plan-detail">
            <div class="card h-100">
                <div class="card-body">
                    <h3 class="h5 mb-2">{{selectedtemplatename}}</h3>
                    <div class="small text-muted mb-2">
                        {{#str}}competencies, core_competency{{/str}}: <strong>{{competencycount}}</strong>
                    </div>
                    {{#canmanage}}
                    <div class="mb-2">
                        <label class="d-block small text-muted mb-1" for="local-dimensions-central-competency-add">
                            {{#str}}central_addcompetency, local_dimensions{{/str}}
                        </label>
                        <select id="local-dimensions-central-competency-add" data-region="competency-add"
                                data-templateid="{{selectedtemplateid}}" data-exclude="{{excludeids}}"
                                class="form-select">
                        </select>
                        <button type="button" class="btn btn-link btn-sm px-0 mt-1" data-action="browse-frameworks">
                            <i class="fa fa-sitemap me-1" aria-hidden="true"></i>
                            {{#str}}central_browseframeworks, local_dimensions{{/str}}
                        </button>
                    </div>
                    {{/canmanage}}
                    {{#hascompetencies}}
                    <ul class="list-unstyled mb-0 local-dimensions-central-complist">
                        {{#competencies}}
                        <li class="d-flex align-items-center justify-content-between py-1 border-bottom"
                            data-competency="{{id}}">
                            <span class="flex-grow-1">{{shortname}}</span>
                            {{#frameworktag}}
                            <span class="badge bg-light text-muted me-2">{{frameworktag}}</span>
                            {{/frameworktag}}
                            {{#canmanage}}
                            <span class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-link p-1" data-action="move-competency-up"
                                        data-id="{{id}}"
                                        aria-label="{{#str}}central_movecompetencyup, local_dimensions{{/str}}"
                                        {{#first}}disabled{{/first}}>
                                    <i class="fa fa-arrow-up" aria-hidden="true"></i>
                                </button>
                                <button type="button" class="btn btn-link p-1" data-action="move-competency-down"
                                        data-id="{{id}}"
                                        aria-label="{{#str}}central_movecompetencydown, local_dimensions{{/str}}"
                                        {{#last}}disabled{{/last}}>
                                    <i class="fa fa-arrow-down" aria-hidden="true"></i>
                                </button>
                                <button type="button" class="btn btn-link text-danger p-1"
                                        data-action="remove-competency" data-id="{{id}}" data-name="{{shortname}}"
                                        aria-label="{{#str}}central_removecompetency, local_dimensions{{/str}}">
                                    <i class="fa fa-times" aria-hidden="true"></i>
                                </button>
                            </span>
                            {{/canmanage}}
                        </li>
                        {{/competencies}}
                    </ul>
                    {{/hascompetencies}}
                    {{^hascompetencies}}
                    <div class="alert alert-warning mb-0" role="status">{{#str}}nocompetencies, local_dimensions{{/str}}</div>
                    {{/hascompetencies}}
                    {{#canmanage}}
                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-sm btn-primary" data-action="edit-template"
                                data-id="{{selectedtemplateid}}">
                            <i class="fa fa-pencil me-1" aria-hidden="true"></i>{{#str}}edit{{/str}}
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-danger" data-action="delete-template"
                                data-id="{{selectedtemplateid}}" data-name="{{selectedtemplatename}}"
                                data-plancount="{{selectedtemplateplancount}}">
                            <i class="fa fa-trash me-1" aria-hidden="true"></i>{{#str}}delete{{/str}}
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="manage-participants">
                            <i class="fa fa-users me-1" aria-hidden="true"></i>{{#str}}central_participants_manage, local_dimensions{{/str}}
                        </button>
                    </div>
                    {{/canmanage}}
                </div>
            </div>
        </aside>
    </div>
    {{/hastemplates}}

    {{^hastemplates}}
    {{#filteredbycompetency}}
    <div class="alert alert-warning" role="status">{{#str}}central_noplanswithcompetency, local_dimensions{{/str}}</div>
    {{/filteredbycompetency}}
    {{^filteredbycompetency}}
    <div class="alert alert-info" role="status">{{#str}}noplans, local_dimensions{{/str}}</div>
    {{/filteredbycompetency}}
    {{/hastemplates}}
    {{/needscategoryselection}}
</div>
