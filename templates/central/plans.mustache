{{!
    @template local_dimensions/central/plans

    Learning plans tab: template list + the selected template's competencies (cross-framework).
    Master-detail with a draggable resizer (starts 50/50), client-side search over template
    name/idnumber, a multi-competency tag filter, and a "show disabled plans" toggle that
    reveals hidden templates (managers only — non-managers never receive them).

    The System / Course category context selector is rendered once at page level
    (local_dimensions/central/contextbar); this tab receives the resolved context via its
    data attributes and shows the guided empty state when a category is still needed.

    Context variables required:
    * contexttype (string) · selectedcategoryid (int) · contextid (int) · needscategoryselection (bool)
    * hastemplates (bool) · hashiddentemplates (bool)
    * templates (array) {id, name, idnumber, search, competencycount, visible, selected, duedate}
    * selectedtemplateid (int) · selectedtemplatename (string) · selectedtemplatevisible (bool)
    * selectedtemplatehasduedate (bool) · selectedtemplateduedate (string)
    * selectedtemplatedisplaymode (string) · selectedtemplatehasdisplaymode (bool)
    * selectedtemplateplancount (int) · selectedtemplatecohortcount (int)
    * competencyids (string) · CSV of the active filter competency ids
    * competencyfilters (array) {id, label} · filteredbycompetency (bool)
    * hascompetencies (bool) · competencies (array) {id, shortname, idnumber, taxonomy, path,
      frameworktag, frameworkid, first, last}
    * excludeids (string) · comma-separated ids already on the template (browse-modal exclusion)
    * competencycount (int) · canmanage (int) · canassignroles (int)

    Example context (json):
    {
        "contexttype": "system",
        "selectedcategoryid": 0,
        "contextid": 1,
        "needscategoryselection": false,
        "competencyids": "7,9",
        "competencyfilters": [
            {"id": 7, "label": "Communication"},
            {"id": 9, "label": "Teamwork"}
        ],
        "filteredbycompetency": true,
        "hastemplates": true,
        "hashiddentemplates": true,
        "templates": [
            {"id": 4, "name": "Induction plan", "idnumber": "IND-01", "search": "induction plan ind-01",
             "competencycount": 6, "visible": true, "selected": true, "duedate": "31 December 2025"},
            {"id": 5, "name": "Management track", "idnumber": "", "search": "management track",
             "competencycount": 4, "visible": false, "selected": false, "duedate": ""}
        ],
        "selectedtemplateid": 4,
        "selectedtemplatename": "Induction plan",
        "selectedtemplatehasidnumber": true,
        "selectedtemplateidnumber": "IND-01",
        "selectedtemplatehasdescription": true,
        "selectedtemplatedescription": "<p>Onboarding plan for new staff.</p>",
        "selectedtemplatehastype": true,
        "selectedtemplatetype": "Onboarding",
        "selectedtemplatehastag1": true,
        "selectedtemplatetag1": "HR",
        "selectedtemplatehastag2": false,
        "selectedtemplatetag2": "",
        "selectedtemplatehasdisplaymode": true,
        "selectedtemplatedisplaymode": "Competency tracker",
        "selectedtemplatevisible": true,
        "selectedtemplatehasduedate": true,
        "selectedtemplateduedate": "31 December 2025",
        "selectedtemplateplancount": 12,
        "selectedtemplatecohortcount": 3,
        "hascompetencies": true,
        "excludeids": "7,9",
        "competencies": [
            {"id": 7, "shortname": "Communication", "idnumber": "COMM-01", "taxonomy": "Competency",
             "path": "Soft skills / Interpersonal", "frameworktag": "CORE", "frameworkid": 5,
             "first": true, "last": false},
            {"id": 9, "shortname": "Teamwork", "idnumber": "", "taxonomy": "Competency",
             "path": "", "frameworktag": "SOFT", "frameworkid": 6, "first": false, "last": true}
        ],
        "competencycount": 6,
        "canmanage": 1,
        "canassignroles": 1
    }
}}
<div class="local-dimensions-central-plans" data-region="plans"
     data-contexttype="{{contexttype}}" data-categoryid="{{selectedcategoryid}}"
     data-contextid="{{contextid}}" data-templateid="{{selectedtemplateid}}"
     data-templatename="{{selectedtemplatename}}" data-competencyids="{{competencyids}}"
     data-excludeids="{{excludeids}}" data-canassignroles="{{canassignroles}}">
    {{#needscategoryselection}}
    <div class="alert alert-info" role="status">{{#str}}managecompetencies_selectcategory_help, local_dimensions{{/str}}</div>
    {{/needscategoryselection}}

    {{^needscategoryselection}}
    {{#hashiddentemplates}}
    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="local-dimensions-plans-showdisabled"
               data-action="toggle-disabled">
        <label class="form-check-label" for="local-dimensions-plans-showdisabled">
            {{#str}}central_plans_showdisabled, local_dimensions{{/str}}
        </label>
    </div>
    {{/hashiddentemplates}}

    <div class="local-dimensions-central-plans-body{{^hastemplates}} local-dimensions-central-plans-body-single{{/hastemplates}}" data-region="plans-body">
        <section class="local-dimensions-central-plans-list-pane" data-region="template-list">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center gap-3 py-2">
                    <span class="fw-semibold flex-grow-1">{{#str}}central_plans_templatestitle, local_dimensions{{/str}}</span>
                    <button type="button" class="btn btn-sm btn-link p-0 ms-auto text-decoration-none" data-action="list-display-options"
                            aria-expanded="true" aria-controls="local-dimensions-plans-listopts"
                            title="{{#str}}managecompetencies_displayoptions, local_dimensions{{/str}}">
                        <i class="fa fa-cog" aria-hidden="true"></i>
                        <span class="visually-hidden">{{#str}}managecompetencies_displayoptions, local_dimensions{{/str}}</span>
                    </button>
                </div>
                <div class="card-body border-bottom py-2 flex-grow-0" id="local-dimensions-plans-listopts"
                     data-region="list-display-options-panel" role="group"
                     aria-label="{{#str}}managecompetencies_displayoptions, local_dimensions{{/str}}">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="local-dimensions-plans-list-id" data-list-toggle="id">
                        <label class="form-check-label" for="local-dimensions-plans-list-id">
                            {{#str}}managecompetencies_showids, local_dimensions{{/str}}
                        </label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="local-dimensions-plans-list-duedate" data-list-toggle="duedate">
                        <label class="form-check-label" for="local-dimensions-plans-list-duedate">
                            {{#str}}central_plans_showduedate, local_dimensions{{/str}}
                        </label>
                    </div>
                </div>
                <div class="card-body border-bottom py-2 flex-grow-0">
                    <div class="d-flex flex-wrap align-items-center gap-3" data-region="plan-toolbar">
                        <div class="flex-grow-1">
                            <label class="visually-hidden" for="local-dimensions-plans-search">
                                {{#str}}managetemplates_searchplaceholder, local_dimensions{{/str}}
                            </label>
                            <input type="search" class="form-control" id="local-dimensions-plans-search"
                                   data-region="plan-search-input" autocomplete="off"
                                   placeholder="{{#str}}managetemplates_searchplaceholder, local_dimensions{{/str}}">
                        </div>
                        {{#canmanage}}
                        <div class="ms-auto">
                            <button type="button" class="btn btn-primary btn-sm" data-action="new-template">
                                <i class="fa fa-plus me-1" aria-hidden="true"></i>{{#str}}managetemplates_addtemplate, local_dimensions{{/str}}
                            </button>
                        </div>
                        {{/canmanage}}
                    </div>
                    <div class="mt-2" data-region="competency-filter">
                        <div class="d-flex flex-wrap align-items-center justify-content-between">
                            <span class="small text-muted">{{#str}}central_plans_filterbycompetencies, local_dimensions{{/str}}</span>
                            {{#filteredbycompetency}}
                            <button type="button" class="btn btn-sm btn-link p-0 text-decoration-none" data-action="clear-competency">
                                <i class="fa fa-times me-1" aria-hidden="true"></i>{{#str}}central_clearcompetencyfilter, local_dimensions{{/str}}
                            </button>
                            {{/filteredbycompetency}}
                        </div>
                        <div class="d-flex flex-wrap align-items-center gap-2 mt-1">
                            {{#competencyfilters}}
                            <span class="badge local-dimensions-central-chip-accent">
                                {{label}}
                                <button type="button" class="btn btn-link p-0 ms-1 local-dimensions-central-chip-remove"
                                        data-action="remove-filter-competency" data-id="{{id}}"
                                        aria-label="{{#str}}central_plans_removefilter, local_dimensions, {{label}}{{/str}}">
                                    <i class="fa fa-times" aria-hidden="true"></i>
                                </button>
                            </span>
                            {{/competencyfilters}}
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="add-filter-competency"
                                    aria-expanded="false" aria-controls="local-dimensions-plans-filterpicker">
                                <i class="fa fa-plus me-1" aria-hidden="true"></i>{{#str}}central_plans_addfilter, local_dimensions{{/str}}
                            </button>
                        </div>
                        <div class="mt-2" id="local-dimensions-plans-filterpicker" data-region="competency-filter-picker" hidden>
                            <label class="visually-hidden" for="local-dimensions-central-competency-search">
                                {{#str}}central_searchcompetency, local_dimensions{{/str}}
                            </label>
                            <select id="local-dimensions-central-competency-search" data-region="competency-search" class="form-select">
                            </select>
                        </div>
                    </div>
                </div>
                <div class="card-body p-2 local-dimensions-central-plans-scroll" data-region="template-rows">
                    {{#templates}}
                    <button type="button"
                            class="btn btn-link text-start text-decoration-none w-100 px-2 py-1 local-dimensions-central-row {{#selected}}active{{/selected}}{{^visible}} local-dimensions-central-plan-hidden{{/visible}}"
                            data-action="select-template" data-id="{{id}}" data-region="template-row"
                            data-search="{{search}}">
                        <i class="fa fa-clipboard-list me-2 text-muted" aria-hidden="true"></i>
                        <span class="flex-grow-1 text-truncate">{{name}}</span>
                        {{#idnumber}}<span class="local-dimensions-central-plan-id text-muted small ms-2 text-nowrap">{{idnumber}}</span>{{/idnumber}}
                        {{#duedate}}<span class="local-dimensions-central-plan-duedate text-muted small ms-2 text-nowrap">{{duedate}}</span>{{/duedate}}
                        <span class="badge {{#selected}}local-dimensions-central-chip-accent{{/selected}}{{^selected}}bg-light text-muted{{/selected}}">{{competencycount}}</span>
                        {{^visible}}<span class="badge bg-secondary ms-1">{{#str}}hidden, tool_lp{{/str}}</span>{{/visible}}
                    </button>
                    {{/templates}}
                    <div class="alert alert-info mb-0 mt-2" data-region="plan-search-empty" hidden>
                        {{#str}}managetemplates_emptysearch, local_dimensions{{/str}}
                    </div>
                    {{^hastemplates}}
                    {{#filteredbycompetency}}
                    <div class="alert alert-warning mb-0" role="status">{{#str}}central_noplanswithcompetency, local_dimensions{{/str}}</div>
                    {{/filteredbycompetency}}
                    {{^filteredbycompetency}}
                    <div class="alert alert-info mb-0" role="status">{{#str}}noplans, local_dimensions{{/str}}</div>
                    {{/filteredbycompetency}}
                    {{/hastemplates}}
                </div>
            </div>
        </section>

        {{#hastemplates}}
        <div class="local-dimensions-central-plans-resizer" data-region="plans-resizer"
             role="separator" aria-orientation="vertical" tabindex="0"
             aria-label="{{#str}}managecompetencies_resizepanels, local_dimensions{{/str}}"></div>

        <aside class="local-dimensions-central-plans-detail-pane" data-region="plan-detail">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center gap-3 py-2">
                    <h3 class="h5 mb-0 flex-grow-1">{{selectedtemplatename}}</h3>
                    <button type="button" class="btn btn-sm btn-link p-0 ms-auto text-decoration-none" data-action="display-options"
                            aria-expanded="true" aria-controls="local-dimensions-plans-displayopts"
                            title="{{#str}}managecompetencies_displayoptions, local_dimensions{{/str}}">
                        <i class="fa fa-cog" aria-hidden="true"></i>
                        <span class="visually-hidden">{{#str}}managecompetencies_displayoptions, local_dimensions{{/str}}</span>
                    </button>
                </div>
                <div class="card-body border-bottom py-2 flex-grow-0" id="local-dimensions-plans-displayopts" data-region="display-options-panel"
                     role="group" aria-label="{{#str}}managecompetencies_displayoptions, local_dimensions{{/str}}">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="local-dimensions-plans-disp-tax"
                               data-display-toggle="tax">
                        <label class="form-check-label" for="local-dimensions-plans-disp-tax">
                            {{#str}}managecompetencies_showtaxonomy, local_dimensions{{/str}}
                        </label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="local-dimensions-plans-disp-path"
                               data-display-toggle="path">
                        <label class="form-check-label" for="local-dimensions-plans-disp-path">
                            {{#str}}central_browseframeworks_showpaths, local_dimensions{{/str}}
                        </label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="local-dimensions-plans-disp-id"
                               data-display-toggle="id">
                        <label class="form-check-label" for="local-dimensions-plans-disp-id">
                            {{#str}}managecompetencies_showids, local_dimensions{{/str}}
                        </label>
                    </div>
                </div>
                <div class="card-body pb-2 flex-grow-0">
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                        <span class="badge local-dimensions-central-chip-accent">
                            {{#str}}central_frameworks_competencies, local_dimensions, {{competencycount}}{{/str}}
                        </span>
                        <span class="badge bg-light text-muted">
                            {{#str}}central_plans_learnerplans, local_dimensions, {{selectedtemplateplancount}}{{/str}}
                        </span>
                        <span class="badge bg-light text-muted">
                            {{#str}}central_plans_cohorts, local_dimensions, {{selectedtemplatecohortcount}}{{/str}}
                        </span>
                        {{#selectedtemplatehastype}}
                            <span class="badge local-dimensions-central-chip-type">{{selectedtemplatetype}}</span>
                        {{/selectedtemplatehastype}}
                        {{#selectedtemplatehastag1}}
                            <span class="badge bg-light text-muted">{{selectedtemplatetag1}}</span>
                        {{/selectedtemplatehastag1}}
                        {{#selectedtemplatehastag2}}
                            <span class="badge bg-light text-muted">{{selectedtemplatetag2}}</span>
                        {{/selectedtemplatehastag2}}
                        {{#selectedtemplatehasdisplaymode}}
                            <span class="badge local-dimensions-central-chip-type">{{selectedtemplatedisplaymode}}</span>
                        {{/selectedtemplatehasdisplaymode}}
                    </div>
                    <div class="d-flex flex-wrap align-items-center column-gap-4 row-gap-1 small mb-0">
                        <span>
                            <span class="text-muted">{{#str}}central_plans_enabled, local_dimensions{{/str}}:</span>
                            {{#selectedtemplatevisible}}<span class="badge bg-success">{{#str}}yes{{/str}}</span>{{/selectedtemplatevisible}}
                            {{^selectedtemplatevisible}}<span class="badge bg-secondary">{{#str}}no{{/str}}</span>{{/selectedtemplatevisible}}
                        </span>
                        <span>
                            <span class="text-muted">{{#str}}managetemplates_duedate, local_dimensions{{/str}}:</span>
                            {{#selectedtemplatehasduedate}}<strong>{{selectedtemplateduedate}}</strong>{{/selectedtemplatehasduedate}}
                            {{^selectedtemplatehasduedate}}<span class="text-muted">{{#str}}managetemplates_duedate_none, local_dimensions{{/str}}</span>{{/selectedtemplatehasduedate}}
                        </span>
                    </div>
                    {{#selectedtemplatehasdescription}}
                        <div class="mt-2 small text-body local-dimensions-central-plans-description">{{{selectedtemplatedescription}}}</div>
                    {{/selectedtemplatehasdescription}}
                </div>
                <div class="card-body py-1 local-dimensions-central-plans-scroll" data-region="competency-list">
                    {{#hascompetencies}}
                    <ul class="list-unstyled mb-0" data-region="competency-items">
                        {{#competencies}}
                        <li class="d-flex align-items-center py-1 border-bottom" data-competency="{{id}}">
                            <span class="flex-grow-1">
                                <span data-region="comp-name">{{shortname}}</span>
                                {{#taxonomy}}
                                <span class="local-dimensions-central-tax small text-muted ms-1">{{taxonomy}}</span>
                                {{/taxonomy}}
                                {{#idnumber}}
                                <span class="local-dimensions-central-id font-monospace small text-muted ms-1">{{idnumber}}</span>
                                {{/idnumber}}
                                {{#path}}
                                <span class="local-dimensions-central-path small text-muted">{{path}}</span>
                                {{/path}}
                            </span>
                            {{#frameworktag}}
                            <span class="badge bg-light text-muted me-2">{{frameworktag}}</span>
                            {{/frameworktag}}
                            {{#canmanage}}
                            <div class="dropdown">
                                {{! Both data attributes: Moodle 4.5 is Bootstrap 4 (data-toggle), 5.x is BS5 (data-bs-toggle). }}
                                <button type="button" class="btn btn-sm btn-link p-1 text-body"
                                        data-toggle="dropdown" data-bs-toggle="dropdown" aria-expanded="false"
                                        aria-label="{{#str}}actions{{/str}}: {{shortname}}">
                                    <i class="fa fa-ellipsis-v" aria-hidden="true"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-right dropdown-menu-end">
                                    <li>
                                        <button type="button" class="dropdown-item" data-action="edit-competency"
                                                data-id="{{id}}" data-frameworkid="{{frameworkid}}">
                                            <i class="fa fa-pencil me-2" aria-hidden="true"></i>{{#str}}editcompetency, tool_lp{{/str}}
                                        </button>
                                    </li>
                                    <li>
                                        <button type="button" class="dropdown-item" data-action="move-competency-up"
                                                data-id="{{id}}"{{#first}} disabled{{/first}}>
                                            <i class="fa fa-arrow-up me-2" aria-hidden="true"></i>{{#str}}moveup{{/str}}
                                        </button>
                                    </li>
                                    <li>
                                        <button type="button" class="dropdown-item" data-action="move-competency-down"
                                                data-id="{{id}}"{{#last}} disabled{{/last}}>
                                            <i class="fa fa-arrow-down me-2" aria-hidden="true"></i>{{#str}}movedown{{/str}}
                                        </button>
                                    </li>
                                    <li>
                                        <button type="button" class="dropdown-item" data-action="move-competency-to"
                                                data-id="{{id}}">
                                            <i class="fa fa-arrows-v me-2" aria-hidden="true"></i>{{#str}}central_plans_moveto, local_dimensions{{/str}}
                                        </button>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <button type="button" class="dropdown-item text-danger" data-action="remove-competency"
                                                data-id="{{id}}" data-name="{{shortname}}">
                                            <i class="fa fa-times me-2" aria-hidden="true"></i>{{#str}}central_removecompetency, local_dimensions{{/str}}
                                        </button>
                                    </li>
                                </ul>
                            </div>
                            {{! Rendered after the row content (the grip's aria-label embeds the competency
                                name, and Behat name-based clicks match the first document-order hit); the
                                flex order in CSS still paints it at the left edge. }}
                            <button type="button" class="btn btn-link p-0 local-dimensions-central-plan-drag"
                                    data-region="drag-handle" data-action="move-competency-to"
                                    title="{{#str}}central_plans_moveto, local_dimensions{{/str}}"
                                    aria-label="{{#str}}central_plans_moveto, local_dimensions{{/str}}: {{shortname}}">
                                <i class="fa fa-grip-vertical" aria-hidden="true"></i>
                            </button>
                            {{/canmanage}}
                        </li>
                        {{/competencies}}
                    </ul>
                    {{/hascompetencies}}
                    {{^hascompetencies}}
                    <div class="alert alert-warning mb-0" role="status">{{#str}}nocompetencies, local_dimensions{{/str}}</div>
                    {{/hascompetencies}}
                </div>
                {{#canmanage}}
                <div class="card-body pt-2 flex-grow-0 border-top">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <button type="button" class="btn btn-sm btn-primary" data-action="edit-template"
                                data-id="{{selectedtemplateid}}">
                            <i class="fa fa-pencil me-1" aria-hidden="true"></i>{{#str}}central_plans_editdetails, local_dimensions{{/str}}
                        </button>
                        <button type="button" class="btn btn-sm btn-secondary" data-action="browse-frameworks">
                            <i class="fa fa-plus me-1" aria-hidden="true"></i>{{#str}}central_addcompetency, local_dimensions{{/str}}
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="manage-participants">
                            <i class="fa fa-users me-1" aria-hidden="true"></i>{{#str}}central_participants_manage, local_dimensions{{/str}}
                        </button>
                        <div class="dropdown">
                            {{! Both data attributes: Moodle 4.5 is Bootstrap 4 (data-toggle), 5.x is BS5 (data-bs-toggle). }}
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    data-toggle="dropdown" data-bs-toggle="dropdown" aria-expanded="false"
                                    aria-label="{{#str}}central_plans_moreactions, local_dimensions{{/str}}">
                                <i class="fa fa-ellipsis-h" aria-hidden="true"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-right dropdown-menu-end">
                                <li>
                                    <button type="button" class="dropdown-item" data-action="duplicate-template"
                                            data-id="{{selectedtemplateid}}">
                                        <i class="fa fa-clone me-2" aria-hidden="true"></i>{{#str}}managetemplates_duplicate, local_dimensions{{/str}}
                                    </button>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <button type="button" class="dropdown-item text-danger" data-action="delete-template"
                                            data-id="{{selectedtemplateid}}" data-name="{{selectedtemplatename}}"
                                            data-plancount="{{selectedtemplateplancount}}">
                                        <i class="fa fa-trash me-2" aria-hidden="true"></i>{{#str}}managetemplates_delete, local_dimensions{{/str}}
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                {{/canmanage}}
            </div>
        </aside>
        {{/hastemplates}}
    </div>
    {{#hastemplates}}
    <div class="local-dimensions-central-plans-vresizer" data-region="plans-vresizer"
         role="separator" aria-orientation="horizontal" tabindex="0"
         aria-label="{{#str}}managecompetencies_resizepanels, local_dimensions{{/str}}"></div>
    {{/hastemplates}}
    {{/needscategoryselection}}
</div>
