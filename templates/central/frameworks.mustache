{{!
    @template local_dimensions/central/frameworks

    Structures (frameworks) tab: a single-column list of structure cards in the resolved
    context. A standalone pill toggle (shown only when hidden structures exist) reveals the
    hidden ones; a sub-header shows the listed count (with a "· N hidden" suffix) and the
    New / Import / Export actions. Each card opens the structure in the Competencies tab and
    carries an actions menu (edit, duplicate, hide/show, export, delete). The System / Course
    category selector is rendered once at page level (contextbar).

    Context variables required:
    * contexttype (string) · selectedcategoryid (int) · contextid (int) · needscategoryselection (bool)
    * hasframeworks (bool) · frameworkcount (int) · hasexcluded (bool) · hiddenlabel (string)
    * canmanage (int) · canscalespage (int) · canexport (int) · showhidden (bool)
    * showhiddentoggle (object|null) {id, label, action, checked}
    * frameworks (array) {id, shortname, idnumber, description, competencycount, competencylabel,
      visible, deletable, canmanage}

    Example context (json):
    {
        "contexttype": "system",
        "selectedcategoryid": 0,
        "contextid": 1,
        "needscategoryselection": false,
        "hasframeworks": true,
        "frameworkcount": 1,
        "hasexcluded": true,
        "hiddenlabel": "1 hidden",
        "canmanage": 1,
        "canscalespage": 1,
        "canexport": 1,
        "showhidden": false,
        "showhiddentoggle": {
            "id": "local-dimensions-frameworks-showhidden",
            "label": "Show hidden structures",
            "action": "toggle-hidden",
            "checked": false
        },
        "frameworks": [
            {"id": 5, "shortname": "Core skills", "idnumber": "CORE",
             "description": "Baseline competencies for the current cohort.",
             "competencycount": 12, "competencylabel": "competencies",
             "visible": true, "deletable": false, "canmanage": true}
        ]
    }
}}
<div class="local-dimensions-central-frameworks" data-region="frameworks"
     data-contexttype="{{contexttype}}" data-categoryid="{{selectedcategoryid}}" data-contextid="{{contextid}}"
     data-canmanage="{{canmanage}}" data-canscalespage="{{canscalespage}}">

    {{#needscategoryselection}}
    <div class="alert alert-info" role="status">{{#str}}managecompetencies_selectcategory_help, local_dimensions{{/str}}</div>
    {{/needscategoryselection}}

    {{^needscategoryselection}}
    {{#showhiddentoggle}}
    {{> local_dimensions/central/showhidden_toggle }}
    {{/showhiddentoggle}}

    <div class="local-dimensions-central-fwtoolbar">
        <span class="local-dimensions-central-fwcount">
            {{#str}}central_frameworks_listed, local_dimensions{{/str}}: <strong>{{frameworkcount}}</strong>{{#hasexcluded}}<span class="local-dimensions-central-fwexcluded"> · {{hiddenlabel}}</span>{{/hasexcluded}}
        </span>
        {{#canmanage}}
        <div class="local-dimensions-central-fwactions">
            <button type="button" class="local-dimensions-central-plans-new" data-action="new">
                <i class="fa fa-plus" aria-hidden="true"></i>{{#str}}central_frameworks_new, local_dimensions{{/str}}
            </button>
            <button type="button" class="local-dimensions-central-btn-outline" data-action="import">
                <i class="fa fa-upload" aria-hidden="true"></i>{{#str}}central_frameworks_import, local_dimensions{{/str}}
            </button>
            {{#canexport}}
            <button type="button" class="local-dimensions-central-btn-outline" data-action="export">
                <i class="fa fa-download" aria-hidden="true"></i>{{#str}}central_frameworks_export, local_dimensions{{/str}}
            </button>
            {{/canexport}}
        </div>
        {{/canmanage}}
    </div>

    {{#hasframeworks}}
    <div class="local-dimensions-central-fwlist" data-region="framework-rows">
        {{#frameworks}}
        {{> local_dimensions/central/frameworks_row }}
        {{/frameworks}}
    </div>
    {{/hasframeworks}}

    {{^hasframeworks}}
    <div class="alert alert-info" role="status">{{#str}}central_frameworks_none, local_dimensions{{/str}}</div>
    {{/hasframeworks}}
    {{/needscategoryselection}}
</div>
