{{!
    @template local_dimensions/central/frameworks

    Frameworks tab: list frameworks in the resolved context with native management actions.
    The System / Course category selector is rendered once at page level (contextbar).

    Context variables required:
    * contexttype (string) · selectedcategoryid (int) · contextid (int) · needscategoryselection (bool)
    * hasframeworks (bool) · frameworkcount (int) · canmanage (int) · canexport (int) · showhidden (bool)
    * hashiddenframeworks (bool)
    * frameworks (array) {id, shortname, idnumber, competencycount, visible, deletable, canmanage}

    Example context (json):
    {
        "contexttype": "system",
        "selectedcategoryid": 0,
        "contextid": 1,
        "needscategoryselection": false,
        "hasframeworks": true,
        "frameworkcount": 1,
        "canmanage": 1,
        "canexport": 1,
        "showhidden": false,
        "hashiddenframeworks": true,
        "frameworks": [
            {"id": 5, "shortname": "Core skills", "idnumber": "CORE", "competencycount": 12,
             "visible": true, "deletable": false, "canmanage": true}
        ]
    }
}}
<div class="local-dimensions-central-frameworks" data-region="frameworks"
     data-contexttype="{{contexttype}}" data-categoryid="{{selectedcategoryid}}" data-contextid="{{contextid}}"
     data-canmanage="{{canmanage}}">

    {{#needscategoryselection}}
    <div class="alert alert-info" role="status">{{#str}}managecompetencies_selectcategory_help, local_dimensions{{/str}}</div>
    {{/needscategoryselection}}

    {{^needscategoryselection}}
    {{#hashiddenframeworks}}
    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="local-dimensions-frameworks-showhidden"
               data-action="toggle-hidden"{{#showhidden}} checked{{/showhidden}}>
        <label class="form-check-label" for="local-dimensions-frameworks-showhidden">
            {{#str}}managecompetencies_showhiddenframeworks, local_dimensions{{/str}}
        </label>
    </div>
    {{/hashiddenframeworks}}
    <div class="d-flex flex-wrap align-items-end gap-3 mb-3">
        <div class="text-muted small">
            {{#str}}central_frameworks_items, local_dimensions{{/str}}: <strong>{{frameworkcount}}</strong>
        </div>
        {{#canmanage}}
        <div class="d-flex flex-wrap gap-2 ms-auto">
            <button type="button" class="btn btn-primary btn-sm" data-action="new">
                <i class="fa fa-plus me-1" aria-hidden="true"></i>{{#str}}central_frameworks_new, local_dimensions{{/str}}
            </button>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-action="import">
                <i class="fa fa-upload me-1" aria-hidden="true"></i>{{#str}}central_frameworks_import, local_dimensions{{/str}}
            </button>
            {{#canexport}}
            <button type="button" class="btn btn-outline-secondary btn-sm" data-action="export">
                <i class="fa fa-download me-1" aria-hidden="true"></i>{{#str}}central_frameworks_export, local_dimensions{{/str}}
            </button>
            {{/canexport}}
        </div>
        {{/canmanage}}
    </div>

    {{#hasframeworks}}
    <div class="card">
        <div class="card-body p-2" data-region="framework-rows">
            {{#frameworks}}
            {{> local_dimensions/central/frameworks_row }}
            {{/frameworks}}
        </div>
    </div>
    {{/hasframeworks}}

    {{^hasframeworks}}
    <div class="alert alert-info" role="status">{{#str}}central_frameworks_none, local_dimensions{{/str}}</div>
    {{/hasframeworks}}
    {{/needscategoryselection}}
</div>
