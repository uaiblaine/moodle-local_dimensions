{{!
    @template local_dimensions/central/competency_links

    Body shell for the "Courses & activities" modal. The course rows and per-course activity rows are
    rendered client-side by local_dimensions/central/competency_links; this shell carries the add-course
    autocomplete select and the empty/load-more regions.

    Context variables required:
    * competencyid (int)

    Example context (json):
    {
        "competencyid": 7
    }
}}
<div class="local-dimensions-central-links" data-region="competency-links">
    <div class="alert alert-warning" role="status" tabindex="-1" data-region="hiddenframework" hidden>
        {{#str}}central_links_hiddenframework, local_dimensions{{/str}}
    </div>
    <div class="mb-3">
        <label class="d-block small text-muted mb-1" for="local-dimensions-links-add">
            {{#str}}central_links_addcourse, local_dimensions{{/str}}
        </label>
        <select id="local-dimensions-links-add"
                class="form-select"
                data-region="course-add"
                data-competencyid="{{competencyid}}"
                data-exclude=""></select>
    </div>
    <div data-region="course-rows"></div>
    <div class="text-muted small" role="status" data-region="course-empty" hidden>
        {{#str}}central_links_nocourses, local_dimensions{{/str}}
    </div>
    <div class="text-center mt-2" data-region="loadmore-wrap" hidden>
        <button type="button" class="btn btn-sm btn-link" data-action="loadmore">
            {{#str}}central_links_loadmore, local_dimensions{{/str}}
        </button>
    </div>
</div>
