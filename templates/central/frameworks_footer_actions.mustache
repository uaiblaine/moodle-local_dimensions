{{!
    @template local_dimensions/central/frameworks_footer_actions

    Management actions for the selected competency framework, rendered into the page sticky
    footer by the Frameworks tab. Buttons act on the module-level selected row, so they carry
    no per-item dataset. Follows core's raw sticky-footer button pattern (btn py-0 d-flex
    flex-column): the icon sits above a centred label, no colour variant; the row is centred.

    Context variables required for this template:
    * canmanage (bool) - whether the current user may manage frameworks
    * visible (bool) - whether the selected framework is currently visible (chooses the eye icon)

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "canmanage": true,
        "visible": true
    }
}}
<div class="sticky-footer-content-wrapper h-100 d-flex justify-content-center">
    <div class="sticky-footer-content local-dimensions-central-footer-actions w-100 d-flex align-items-center gap-2 px-3 py-2">
        {{#canmanage}}
        <button type="button" class="btn py-0 d-flex flex-column align-items-center" data-action="edit">
            <i class="fa fa-pencil" aria-hidden="true"></i>
            <span>{{#str}}central_plans_editdetails, local_dimensions{{/str}}</span>
        </button>
        <button type="button" class="btn py-0 d-flex flex-column align-items-center" data-action="visibility">
            <i class="fa {{#visible}}fa-eye{{/visible}}{{^visible}}fa-eye-slash{{/visible}}" aria-hidden="true"></i>
            <span>{{#str}}central_frameworks_visibility, local_dimensions{{/str}}</span>
        </button>
        <button type="button" class="btn py-0 d-flex flex-column align-items-center" data-action="duplicate">
            <i class="fa fa-copy" aria-hidden="true"></i>
            <span>{{#str}}central_frameworks_duplicate, local_dimensions{{/str}}</span>
        </button>
        <button type="button" class="btn py-0 d-flex flex-column align-items-center" data-action="delete">
            <i class="fa fa-trash" aria-hidden="true"></i>
            <span>{{#str}}delete{{/str}}</span>
        </button>
        {{/canmanage}}
    </div>
</div>
