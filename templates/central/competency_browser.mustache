{{!
    @template local_dimensions/central/competency_browser

    Body of the "Browse frameworks" modal: a framework selector on top of the shared
    framework browser partial (central/competency_tree_browser — filter, show-paths toggle
    and lazy tree list), driven by the local_dimensions/central/competency_browser AMD module.

    Context variables required:
    * hasframeworks (bool)
    * frameworks (array) {id, shortname, selected}

    Example context (json):
    {
        "hasframeworks": true,
        "frameworks": [
            {"id": 3, "shortname": "Core skills", "selected": true},
            {"id": 5, "shortname": "Soft skills", "selected": false}
        ]
    }
}}
<div class="local-dimensions-competency-browser" data-region="competency-browser">
    {{#hasframeworks}}
    <div class="mb-2">
        <label class="d-block small text-muted mb-1" for="local-dimensions-cb-framework">
            {{#str}}central_browseframeworks_framework, local_dimensions{{/str}}
        </label>
        <select id="local-dimensions-cb-framework" data-region="framework" class="form-select">
            {{#frameworks}}
            <option value="{{id}}" {{#selected}}selected{{/selected}}>{{shortname}}</option>
            {{/frameworks}}
        </select>
    </div>
    {{> local_dimensions/central/competency_tree_browser }}
    {{/hasframeworks}}
    {{^hasframeworks}}
    <div class="alert alert-info mb-0" role="status">
        {{#str}}central_browseframeworks_noframeworks, local_dimensions{{/str}}
    </div>
    {{/hasframeworks}}
</div>
