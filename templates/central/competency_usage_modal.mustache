{{!
    @template local_dimensions/central/competency_usage_modal

    Body of the competency usage modal on the Structure tab. Only the section matching
    the counter the user clicked is rendered (show* flags): linked courses, linked
    activities (each labelled with its course) or the learning plan templates bundling
    the competency — the modal title carries the section name. Each section is a striped,
    roomy table with column headers, mirroring the Manage participants grid; courses and
    activities open in a new tab. Rendered client-side by local_dimensions/central/structure
    from the local_dimensions_competency_usage web service response.

    Context variables required:
    * showcourses (bool) · hascourses (bool) · courses (array) {id, name, shortname, url}
    * showactivities (bool) · hasactivities (bool) · activities (array) {cmid, name, coursename, courseshortname, url}
    * showtemplates (bool) · hastemplates (bool) · templates (array) {id, name, visible}

    Example context (json):
    {
        "showcourses": true,
        "hascourses": true,
        "courses": [
            {"id": 3, "name": "Communication 101", "shortname": "COMM101",
             "url": "https://moodle.example.com/course/view.php?id=3"}
        ],
        "showactivities": true,
        "hasactivities": true,
        "activities": [
            {"cmid": 12, "name": "Final essay", "coursename": "Communication 101",
             "courseshortname": "COMM101", "url": "https://moodle.example.com/mod/assign/view.php?id=12"}
        ],
        "showtemplates": true,
        "hastemplates": true,
        "templates": [
            {"id": 4, "name": "Induction plan", "visible": true}
        ]
    }
}}
<div class="local-dimensions-central-usage">
    {{#showcourses}}
    {{#hascourses}}
    <table class="table table-striped table-hover generaltable mb-0">
        <caption class="visually-hidden">{{#str}}managecompetencies_linkedcourses, local_dimensions{{/str}}</caption>
        <thead>
            <tr>
                <th scope="col">{{#str}}central_usage_col_course, local_dimensions{{/str}}</th>
                <th scope="col">{{#str}}central_usage_col_shortname, local_dimensions{{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#courses}}
            <tr>
                <td>
                    {{#url}}
                    <a href="{{url}}" target="_blank" rel="noopener noreferrer">{{name}}<i class="fa fa-external-link ms-1" aria-hidden="true"></i><span class="visually-hidden">{{#str}}opensinnewwindow, core{{/str}}</span></a>
                    {{/url}}
                    {{^url}}{{name}}{{/url}}
                </td>
                <td><span class="font-monospace small text-muted">{{shortname}}</span></td>
            </tr>
            {{/courses}}
        </tbody>
    </table>
    {{/hascourses}}
    {{^hascourses}}
    <p class="text-muted small mb-0">{{#str}}central_links_nocourses, local_dimensions{{/str}}</p>
    {{/hascourses}}
    {{/showcourses}}

    {{#showactivities}}
    {{#hasactivities}}
    <table class="table table-striped table-hover generaltable mb-0">
        <caption class="visually-hidden">{{#str}}managecompetencies_linkedactivities, local_dimensions{{/str}}</caption>
        <thead>
            <tr>
                <th scope="col">{{#str}}central_usage_col_activity, local_dimensions{{/str}}</th>
                <th scope="col">{{#str}}central_usage_col_course, local_dimensions{{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#activities}}
            <tr>
                <td>
                    {{#url}}
                    <a href="{{url}}" target="_blank" rel="noopener noreferrer">{{name}}<i class="fa fa-external-link ms-1" aria-hidden="true"></i><span class="visually-hidden">{{#str}}opensinnewwindow, core{{/str}}</span></a>
                    {{/url}}
                    {{^url}}{{name}}{{/url}}
                </td>
                <td>
                    {{coursename}}
                    <span class="font-monospace small text-muted ms-1">{{courseshortname}}</span>
                </td>
            </tr>
            {{/activities}}
        </tbody>
    </table>
    {{/hasactivities}}
    {{^hasactivities}}
    <p class="text-muted small mb-0">{{#str}}central_usage_noactivities, local_dimensions{{/str}}</p>
    {{/hasactivities}}
    {{/showactivities}}

    {{#showtemplates}}
    {{#hastemplates}}
    <table class="table table-striped table-hover generaltable mb-0">
        <caption class="visually-hidden">{{#str}}central_structure_linkedplans, local_dimensions{{/str}}</caption>
        <thead>
            <tr>
                <th scope="col">{{#str}}central_usage_col_plan, local_dimensions{{/str}}</th>
                <th scope="col">{{#str}}central_usage_col_status, local_dimensions{{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#templates}}
            <tr>
                <td>{{name}}</td>
                <td>
                    {{#visible}}<span class="badge bg-success">{{#str}}visible, tool_lp{{/str}}</span>{{/visible}}
                    {{^visible}}<span class="badge bg-secondary">{{#str}}hidden, tool_lp{{/str}}</span>{{/visible}}
                </td>
            </tr>
            {{/templates}}
        </tbody>
    </table>
    {{/hastemplates}}
    {{^hastemplates}}
    <p class="text-muted small mb-0">{{#str}}central_usage_noplans, local_dimensions{{/str}}</p>
    {{/hastemplates}}
    {{/showtemplates}}
</div>
