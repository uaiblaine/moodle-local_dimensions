{{!
    @template local_dimensions/central/frameworks_row

    One competency framework row in the Frameworks tab.

    Context variables required:
    * id, shortname, idnumber (string) · competencycount (int)
    * visible, deletable, canmanage (bool)

    Example context (json):
    {
        "id": 5,
        "shortname": "Core skills",
        "idnumber": "CORE",
        "competencycount": 12,
        "visible": true,
        "deletable": false,
        "canmanage": true
    }
}}
<div class="d-flex align-items-center border-bottom local-dimensions-central-framework"
     data-framework="{{id}}" data-frameworkid="{{id}}" data-name="{{shortname}}"
     data-count="{{competencycount}}" data-visible="{{#visible}}1{{/visible}}{{^visible}}0{{/visible}}"
     data-deletable="{{#deletable}}1{{/deletable}}{{^deletable}}0{{/deletable}}">
    <button type="button"
            class="btn text-start text-decoration-none flex-grow-1 py-2 local-dimensions-central-framework-select"
            data-action="select-framework">
        <span class="fw-bold">{{shortname}}</span>
        {{#idnumber}}<span class="text-muted small ms-2">{{idnumber}}</span>{{/idnumber}}
        <span class="text-muted small ms-2">{{#str}}central_frameworks_competencies, local_dimensions, {{competencycount}}{{/str}}</span>
        {{^visible}}<span class="badge bg-secondary ms-2">{{#str}}hidden, tool_lp{{/str}}</span>{{/visible}}
    </button>
</div>
