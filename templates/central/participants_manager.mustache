{{!
    @template local_dimensions/central/participants_manager

    Body of the "Manage participants" modal: a header and Cohorts/Users tabs. The Cohorts pane is filled
    by local_dimensions/central/cohort_manager (mount); the Users grid rows by
    local_dimensions/central/participants_users.

    Context variables required:
    * templatename (string) · contextid (int) · canassignroles (bool)

    Example context (json):
    {
        "templatename": "Induction plan",
        "contextid": 1,
        "canassignroles": true
    }
}}
<div class="local-dimensions-participants" data-region="participants" data-contextid="{{contextid}}">
    <div class="local-dimensions-participants-header mb-2">
        <h5 class="mb-0">{{templatename}}</h5>
    </div>
    <ul class="nav nav-tabs mb-3" role="tablist" data-region="participant-tabs">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" type="button" role="tab" id="local-dimensions-tab-cohorts"
                    aria-controls="local-dimensions-pane-cohorts" data-region="tab-cohorts"
                    data-target-pane="pane-cohorts" aria-selected="true">
                {{#str}}central_participants_tab_cohorts, local_dimensions{{/str}}
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" type="button" role="tab" id="local-dimensions-tab-users"
                    aria-controls="local-dimensions-pane-users" data-region="tab-users"
                    data-target-pane="pane-users" aria-selected="false">
                {{#str}}central_participants_tab_users, local_dimensions{{/str}}
            </button>
        </li>
        {{#canassignroles}}
        <li class="nav-item" role="presentation">
            <button class="nav-link" type="button" role="tab" id="local-dimensions-tab-roles"
                    aria-controls="local-dimensions-pane-roles" data-region="tab-roles"
                    data-target-pane="pane-roles" aria-selected="false">
                {{#str}}central_roles_tab, local_dimensions{{/str}}
            </button>
        </li>
        {{/canassignroles}}
    </ul>
    <div class="tab-content">
        <div class="tab-pane fade show active" id="local-dimensions-pane-cohorts" role="tabpanel"
             aria-labelledby="local-dimensions-tab-cohorts" data-region="pane-cohorts"></div>
        <div class="tab-pane fade" id="local-dimensions-pane-users" role="tabpanel"
             aria-labelledby="local-dimensions-tab-users" data-region="pane-users">
            <div class="d-flex align-items-end mb-2">
                <div class="flex-grow-1 me-2">
                    <label class="d-block small text-muted mb-1" for="local-dimensions-participant-add">
                        {{#str}}central_participants_add, local_dimensions{{/str}}
                    </label>
                    <select id="local-dimensions-participant-add" data-region="participant-add"
                            class="form-select"></select>
                </div>
                {{! Both data attributes: Moodle 4.5 is Bootstrap 4 (data-toggle), 5.x is BS5 (data-bs-toggle).
                    The controls sit in a <form> so BS4 keeps the dropdown open for clicks inside it;
                    data-bs-auto-close does the same on BS5. }}
                <div class="dropdown" data-region="participant-filters">
                    <button class="btn btn-outline-secondary" type="button"
                            id="local-dimensions-participant-filters-toggle"
                            data-toggle="dropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside"
                            aria-haspopup="true" aria-expanded="false">
                        <i class="fa fa-filter me-1" aria-hidden="true"></i>{{#str}}filters, moodle{{/str}}
                    </button>
                    <div class="dropdown-menu dropdown-menu-right dropdown-menu-end
                                local-dimensions-participants-filters p-3"
                         aria-labelledby="local-dimensions-participant-filters-toggle">
                        <form data-region="participant-filters-form">
                            <div class="mb-2">
                                <label class="d-block small text-muted mb-1"
                                       for="local-dimensions-participant-cohort">
                                    {{#str}}central_participants_cohortfilter, local_dimensions{{/str}}
                                </label>
                                <select id="local-dimensions-participant-cohort" data-region="participant-cohort"
                                        class="form-select"></select>
                            </div>
                            <div class="mb-2">
                                <label class="d-block small text-muted mb-1"
                                       for="local-dimensions-participant-search">
                                    {{#str}}central_participants_search, local_dimensions{{/str}}
                                </label>
                                <input type="text" id="local-dimensions-participant-search"
                                       data-region="participant-search" class="form-control">
                            </div>
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox"
                                       id="local-dimensions-participant-individual"
                                       data-region="participant-individual">
                                <label class="form-check-label" for="local-dimensions-participant-individual">
                                    {{#str}}central_participants_showindividual, local_dimensions{{/str}}
                                </label>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <table class="flexible table table-striped table-hover table generaltable mb-0">
                <caption class="visually-hidden">{{#str}}central_participants_tab_users, local_dimensions{{/str}}</caption>
                <thead>
                    <tr>
                        <th scope="col">{{#str}}central_participants_col_user, local_dimensions{{/str}}</th>
                        <th scope="col">{{#str}}central_participants_col_status, local_dimensions{{/str}}</th>
                        <th scope="col">{{#str}}central_participants_col_model, local_dimensions{{/str}}</th>
                        <th scope="col">{{#str}}central_participants_col_cohort, local_dimensions{{/str}}</th>
                        <th scope="col">{{#str}}central_participants_col_individual, local_dimensions{{/str}}</th>
                        <th scope="col">{{#str}}actions{{/str}}</th>
                    </tr>
                </thead>
                <tbody data-region="participant-rows"></tbody>
            </table>
            <div data-region="participant-sentinel"></div>
        </div>
        {{#canassignroles}}
        <div class="tab-pane fade" id="local-dimensions-pane-roles" role="tabpanel"
             aria-labelledby="local-dimensions-tab-roles" data-region="pane-roles"></div>
        {{/canassignroles}}
    </div>
</div>
