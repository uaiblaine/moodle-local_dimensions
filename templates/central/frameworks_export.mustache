{{!
    @template local_dimensions/central/frameworks_export

    Body of the export-framework modal on the Competency hub Frameworks tab. The framework
    select is populated client-side from the tab's framework rows; the Download button calls
    the local_dimensions_export_framework web service and streams the CSV as a file.

    Context variables required: none (static markup; strings resolved with str helpers).

    Example context (json):
    {
    }
}}
<div data-region="export-body">
    <div class="mb-3">
        <label class="form-label" for="local-dimensions-export-select">
            {{#str}}central_frameworks_export_pick, local_dimensions{{/str}}
        </label>
        <select class="form-select" id="local-dimensions-export-select" data-region="export-select"></select>
    </div>
    <div class="d-flex align-items-center gap-2">
        <button type="button" class="btn btn-primary" data-action="download">
            <i class="fa fa-download me-1" aria-hidden="true"></i>{{#str}}central_frameworks_export, local_dimensions{{/str}}
        </button>
        <span data-region="export-loader" class="d-inline-flex" hidden></span>
    </div>
</div>
