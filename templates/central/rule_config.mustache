{{!
    @template local_dimensions/central/rule_config

    Body of the native competency rule-configuration modal: outcome selector, rule-type selector and
    (for the points rule) a per-child points table. The local_dimensions/central/rule_config AMD module
    toggles the rule-type/points visibility and reads the values on save.

    Context variables required:
    * hasrule (bool) · ispoints (bool) · showerror (bool) · haschildren (bool) · requiredpoints (int)
    * outcomes (array) {value, label, selected}
    * ruletypes (array) {type, name, selected}
    * children (array) {id, shortname, points, required}

    Example context (json):
    {
        "hasrule": true,
        "ispoints": true,
        "showerror": false,
        "haschildren": true,
        "requiredpoints": 2,
        "outcomes": [
            {"value": 0, "label": "None", "selected": false},
            {"value": 2, "label": "Mark as complete", "selected": true}
        ],
        "ruletypes": [
            {"type": "core_competency\\competency_rule_all", "name": "All", "selected": false},
            {"type": "core_competency\\competency_rule_points", "name": "Points", "selected": true}
        ],
        "children": [
            {"id": 7, "shortname": "Listening", "points": 1, "required": true},
            {"id": 9, "shortname": "Speaking", "points": 1, "required": false}
        ]
    }
}}
<div class="local-dimensions-rule-config" data-region="rule-config">
    <div class="mb-3">
        <label class="form-label" for="local-dimensions-rule-outcome">{{#str}}outcome, tool_lp{{/str}}</label>
        <select id="local-dimensions-rule-outcome" data-region="outcome" class="form-select">
            {{#outcomes}}
            <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
            {{/outcomes}}
        </select>
    </div>
    <div class="mb-3" data-region="ruletype-wrap" {{^hasrule}}hidden{{/hasrule}}>
        <label class="form-label" for="local-dimensions-rule-type">{{#str}}central_rule_type, local_dimensions{{/str}}</label>
        <select id="local-dimensions-rule-type" data-region="ruletype" class="form-select">
            {{#ruletypes}}
            <option value="{{type}}" {{#selected}}selected{{/selected}}>{{name}}</option>
            {{/ruletypes}}
        </select>
    </div>
    <div class="alert alert-danger" role="alert" data-region="error" {{^showerror}}hidden{{/showerror}}>
        {{#str}}central_rule_invalidpoints, local_dimensions{{/str}}
    </div>
    <div data-region="points" {{^ispoints}}hidden{{/ispoints}}>
        {{#haschildren}}
        <table class="table table-sm mb-0">
            <thead>
                <tr>
                    <th scope="col"></th>
                    <th scope="col">{{#str}}points, tool_lp{{/str}}</th>
                    <th scope="col">{{#str}}required{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#children}}
                <tr data-competency="{{id}}">
                    <th scope="row">{{shortname}}</th>
                    <td><input type="number" min="0" value="{{points}}" name="points" class="form-control"></td>
                    <td><input type="checkbox" value="1" name="required" {{#required}}checked{{/required}}></td>
                </tr>
                {{/children}}
                <tr>
                    <th scope="row">{{#str}}totalrequiredtocomplete, tool_lp{{/str}}</th>
                    <td><input type="number" min="1" value="{{requiredpoints}}" name="requiredpoints" class="form-control"></td>
                    <td></td>
                </tr>
            </tbody>
        </table>
        {{/haschildren}}
    </div>
</div>
