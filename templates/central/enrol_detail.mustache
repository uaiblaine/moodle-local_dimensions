{{!
    @template local_dimensions/central/enrol_detail

    Body of the course-details modal opened from an Enrolment methods row: a striped label/value
    table plus an open-course link aligned to the right. Every label and line is pre-localised
    by local_dimensions/central/enrol_methods from the row's data attributes: the status lines
    already combine the status label, the configured-since date, the instance's active state and
    the assigned role. The course link opens in a new tab.

    Context variables required:
    * fullname · shortname · categorylabel · categoryname · visiblelabel · visiblevalue (strings)
    * competencylabel · competencyname · cohortlabel · cohortline · selflabel · selfline (strings)
    * courseurl · opencourselabel (strings)

    Example context (json):
    {
        "fullname": "Communication fundamentals",
        "shortname": "MKT-101",
        "categorylabel": "Category",
        "categoryname": "Marketing",
        "visiblelabel": "Visible",
        "visiblevalue": "Yes",
        "competencylabel": "Competency",
        "competencyname": "Corporate communication",
        "cohortlabel": "Cohort sync",
        "cohortline": "Configured Tuesday, 19 May 2026, 2:43 PM · Role: Student",
        "selflabel": "Self enrolment",
        "selfline": "Only cohort members · Not configured",
        "courseurl": "https://example.com/course/view.php?id=42",
        "opencourselabel": "Open course"
    }
}}
<div class="local-dimensions-enrol-detail p-2">
    <h5 class="mb-1">{{fullname}}</h5>
    <p class="text-muted mb-4">{{shortname}}</p>
    <table class="table table-striped local-dimensions-enrol-detail-table mb-4">
        <caption class="visually-hidden">{{fullname}}</caption>
        <tbody>
            <tr>
                <th scope="row" class="fw-medium">{{categorylabel}}</th>
                <td>{{categoryname}}</td>
            </tr>
            <tr>
                <th scope="row" class="fw-medium">{{visiblelabel}}</th>
                <td>{{visiblevalue}}</td>
            </tr>
            <tr>
                <th scope="row" class="fw-medium">{{competencylabel}}</th>
                <td>{{competencyname}}</td>
            </tr>
            <tr>
                <th scope="row" class="fw-medium">{{cohortlabel}}</th>
                <td>{{cohortline}}</td>
            </tr>
            <tr>
                <th scope="row" class="fw-medium">{{selflabel}}</th>
                <td>{{selfline}}</td>
            </tr>
        </tbody>
    </table>
    <div class="d-flex justify-content-end">
        <a href="{{courseurl}}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary">
            <i class="fa fa-arrow-up-right-from-square me-1" aria-hidden="true"></i>{{opencourselabel}}
        </a>
    </div>
</div>
