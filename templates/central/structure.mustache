{{!
    @template local_dimensions/central/structure

    Structure tab: framework switcher + competency tree (master-detail).

    The System / Course category context selector is rendered once at page level
    (local_dimensions/central/contextbar); this tab receives the resolved context via
    its data attributes and shows the guided empty state when a category is still needed.

    Context variables required:
    * contexttype (string) · selectedcategoryid (int) · selectedframeworkid (int) · showhidden (bool)
    * hashiddenframeworks (bool)
    * rulesmodulesjson (string json) · courseoutcomesjson (string json) · moduleoutcomesjson (string json)
    * needscategoryselection (bool)
    * hasframeworks (bool) · frameworks (array) {id, name, idnumber, selected, competencycount, hidden}
    * competencies (array) {id, parentid, shortname, idnumber, indent, haschildren, canmanage, taxonomy,
      coursecount, activitycount, templatecount, rulelabel, depth, ruletype, ruleoutcome, ruleconfig}
    * hascompetencies (bool) · competencycount (int) · rootshown (int) · roottotal (int) · hasmoreroots (bool)
    * canmanage (int)

    Example context (json):
    {
        "contexttype": "system",
        "selectedcategoryid": 0,
        "selectedframeworkid": 5,
        "showhidden": false,
        "hashiddenframeworks": true,
        "rulesmodulesjson": "[]",
        "courseoutcomesjson": "[]",
        "moduleoutcomesjson": "[]",
        "needscategoryselection": false,
        "hasframeworks": true,
        "frameworks": [
            {"id": 5, "name": "Core skills", "idnumber": "CORE", "selected": true, "competencycount": 12, "hidden": false}
        ],
        "competencycount": 12,
        "rootshown": 1,
        "roottotal": 1,
        "hasmoreroots": false,
        "canmanage": 1,
        "hascompetencies": true,
        "competencies": [
            {
                "id": 7, "parentid": 0, "shortname": "Communication", "idnumber": "COMM-01",
                "taxonomy": "Competency", "scale": "Default competence scale",
                "description": "Communicates clearly in writing and speech.",
                "coursecount": 3, "activitycount": 5, "templatecount": 2,
                "depth": 0, "indent": 0, "haschildren": true, "canmanage": true,
                "ruletype": "", "ruleoutcome": 0, "ruleconfig": "", "rulelabel": "No rule"
            }
        ]
    }
}}
<div class="local-dimensions-central-structure" data-region="structure"
     data-contexttype="{{contexttype}}" data-categoryid="{{selectedcategoryid}}" data-frameworkid="{{selectedframeworkid}}"
     data-canmanage="{{canmanage}}"
     data-narule="{{#str}}managecompetencies_rule_notapplicable, local_dimensions{{/str}}">
    <script type="application/json" data-region="rules-modules">{{{rulesmodulesjson}}}</script>
    <script type="application/json" data-region="course-outcomes">{{{courseoutcomesjson}}}</script>
    <script type="application/json" data-region="module-outcomes">{{{moduleoutcomesjson}}}</script>

    {{#needscategoryselection}}
    <div class="alert alert-info" role="status">{{#str}}managecompetencies_selectcategory_help, local_dimensions{{/str}}</div>
    {{/needscategoryselection}}

    {{^needscategoryselection}}
    {{#hashiddenframeworks}}
    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="local-dimensions-structure-showhidden"
               data-action="toggle-hidden"{{#showhidden}} checked{{/showhidden}}>
        <label class="form-check-label" for="local-dimensions-structure-showhidden">
            {{#str}}managecompetencies_showhiddenframeworks, local_dimensions{{/str}}
        </label>
    </div>
    {{/hashiddenframeworks}}
    {{#hasframeworks}}
    <div class="d-flex flex-wrap align-items-end gap-3 mb-3">
        <div>
            <label class="d-block small text-muted mb-1" for="local-dimensions-central-framework">
                {{#str}}central_browseframeworks_framework, local_dimensions{{/str}}
            </label>
            <select id="local-dimensions-central-framework" class="form-select" data-region="framework-select">
                {{#frameworks}}
                <option value="{{id}}" data-hidden="{{#hidden}}1{{/hidden}}"{{#selected}} selected{{/selected}}>{{name}}{{#idnumber}} · {{idnumber}}{{/idnumber}}{{#hidden}} · {{#str}}hidden, tool_lp{{/str}}{{/hidden}}</option>
                {{/frameworks}}
            </select>
        </div>
        <div class="text-muted small">
            {{#str}}managecompetencies_items, local_dimensions{{/str}}: <strong>{{competencycount}}</strong>
        </div>
        {{#canmanage}}
        <div class="ms-auto text-end">
            <button type="button" class="btn btn-primary btn-sm" data-action="add">
                <i class="fa fa-plus me-1" aria-hidden="true"></i>{{#str}}managecompetencies_addcompetency, local_dimensions{{/str}}
            </button>
            <div class="small text-muted mt-1" data-region="add-hint">
                {{#str}}managecompetencies_addhint_root, local_dimensions{{/str}}
            </div>
        </div>
        {{/canmanage}}
    </div>

    {{#hascompetencies}}
    <div class="local-dimensions-central-structure-body" data-region="structure-body">
        <section class="local-dimensions-central-structure-tree-pane" data-region="tree-pane">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center gap-3 py-2">
                    <button type="button" class="btn btn-sm btn-link p-0 text-decoration-none" data-action="expand-all">
                        <i class="fa fa-angle-double-down me-1" aria-hidden="true"></i>{{#str}}managecompetencies_expandall, local_dimensions{{/str}}
                    </button>
                    <button type="button" class="btn btn-sm btn-link p-0 text-decoration-none" data-action="collapse-all">
                        <i class="fa fa-angle-double-up me-1" aria-hidden="true"></i>{{#str}}managecompetencies_collapseall, local_dimensions{{/str}}
                    </button>
                    <button type="button" class="btn btn-sm btn-link p-0 ms-auto text-decoration-none" data-action="display-options"
                            aria-expanded="true" aria-controls="local-dimensions-central-displayopts"
                            title="{{#str}}managecompetencies_displayoptions, local_dimensions{{/str}}">
                        <i class="fa fa-cog" aria-hidden="true"></i>
                        <span class="visually-hidden">{{#str}}managecompetencies_displayoptions, local_dimensions{{/str}}</span>
                    </button>
                </div>
                <div class="card-body border-bottom py-2 flex-grow-0" id="local-dimensions-central-displayopts" data-region="display-options-panel"
                     role="group" aria-label="{{#str}}managecompetencies_displayoptions, local_dimensions{{/str}}">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="local-dimensions-disp-tax" data-display-toggle="tax">
                        <label class="form-check-label" for="local-dimensions-disp-tax">{{#str}}managecompetencies_showtaxonomy, local_dimensions{{/str}}</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="local-dimensions-disp-id" data-display-toggle="id">
                        <label class="form-check-label" for="local-dimensions-disp-id">{{#str}}managecompetencies_showids, local_dimensions{{/str}}</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="local-dimensions-disp-rule" data-display-toggle="rule" checked>
                        <label class="form-check-label" for="local-dimensions-disp-rule">{{#str}}managecompetencies_showrule, local_dimensions{{/str}}</label>
                    </div>
                </div>
                <div class="card-body py-2 border-bottom flex-grow-0 local-dimensions-central-search-wrap">
                    <input type="search" class="form-control form-control-sm" id="local-dimensions-structure-search"
                           data-region="structure-search" autocomplete="off"
                           placeholder="{{#str}}managecompetencies_searchplaceholder, local_dimensions{{/str}}">
                    <div class="list-group local-dimensions-central-searchresults" data-region="search-results" hidden></div>
                </div>
                <div class="card-body p-2 local-dimensions-central-tree local-dimensions-central-structure-scroll show-rule" data-region="competency-tree">
                    {{#competencies}}
                    {{> local_dimensions/central/structure_node }}
                    {{/competencies}}
                    {{#hasmoreroots}}
                    <button type="button" class="btn btn-sm btn-link" data-region="root-loadmore"
                            data-offset="{{rootshown}}" data-total="{{roottotal}}">
                        {{#str}}managecompetencies_loadmore, local_dimensions{{/str}}
                    </button>
                    {{/hasmoreroots}}
                </div>
            </div>
        </section>
        <div class="local-dimensions-central-structure-resizer" data-region="structure-resizer"
             role="separator" aria-orientation="vertical" tabindex="0"
             aria-label="{{#str}}managecompetencies_resizepanels, local_dimensions{{/str}}"></div>
        <aside class="local-dimensions-central-structure-detail-pane" data-region="detail-pane">
            <div class="card h-100">
                <div class="card-body local-dimensions-central-structure-scroll">
                    <div data-region="detail-empty" class="text-muted">
                        <i class="fa fa-info-circle me-1" aria-hidden="true"></i>
                        {{#str}}managecompetencies_selectdetails, local_dimensions{{/str}}
                    </div>
                    <div data-region="detail-content" hidden>
                        <div class="mb-2">
                            <div class="small text-muted">{{#str}}managecompetencies_taxonomy, local_dimensions{{/str}}</div>
                            <div data-region="detail-taxonomy"></div>
                        </div>
                        <div class="mb-2">
                            <div class="small text-muted">{{#str}}name{{/str}}</div>
                            <h3 class="h5 mb-0" data-region="detail-title"></h3>
                        </div>
                        <div class="mb-2">
                            <div class="small text-muted">{{#str}}idnumber{{/str}}</div>
                            <div class="font-monospace" data-region="detail-idnumber"></div>
                        </div>
                        <div class="mb-2" data-region="detail-scale-wrap" hidden>
                            <div class="small text-muted">{{#str}}scale, tool_lp{{/str}}</div>
                            <div data-region="detail-scale"></div>
                        </div>
                        <div class="mb-2" data-region="detail-description-wrap" hidden>
                            <div class="small text-muted">{{#str}}description{{/str}}</div>
                            <div class="small" data-region="detail-description"></div>
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col">
                                <div class="small text-muted">{{#str}}managecompetencies_linkedcourses, local_dimensions{{/str}}</div>
                                <button type="button" class="btn btn-link p-0 text-decoration-underline"
                                        data-action="show-usage" data-usage="courses" data-region="detail-courses"></button>
                            </div>
                            <div class="col">
                                <div class="small text-muted">{{#str}}managecompetencies_linkedactivities, local_dimensions{{/str}}</div>
                                <button type="button" class="btn btn-link p-0 text-decoration-underline"
                                        data-action="show-usage" data-usage="activities" data-region="detail-activities"></button>
                            </div>
                            <div class="col">
                                <div class="small text-muted">{{#str}}central_structure_linkedplans, local_dimensions{{/str}}</div>
                                <button type="button" class="btn btn-link p-0 text-decoration-underline"
                                        data-action="show-usage" data-usage="templates" data-region="detail-plans"></button>
                            </div>
                        </div>
                        <div class="mb-2">
                            <div class="small text-muted">{{#str}}competencyrule, tool_lp{{/str}}</div>
                            <div data-region="detail-rule"></div>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
    {{/hascompetencies}}

    {{^hascompetencies}}
    <div class="alert alert-info" role="status">{{#str}}nocompetencies, local_dimensions{{/str}}</div>
    {{/hascompetencies}}
    {{/hasframeworks}}

    {{^hasframeworks}}
    <div class="alert alert-info" role="status">{{#str}}noframeworks, local_dimensions{{/str}}</div>
    {{/hasframeworks}}
    {{/needscategoryselection}}
</div>
