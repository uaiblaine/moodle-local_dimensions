{{!
    @template local_dimensions/edit_competency_section_open

    Opening markup for a visual competency edit form section.

    Context variables required:
    * id - Section anchor ID.
    * title - Section title.
    * description - Section description.

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<section id="{{id}}" class="local-dimensions-edit-section" data-region="edit-section">
    <div class="local-dimensions-edit-section-head">
        <h2>{{title}}</h2>
        <span class="local-dimensions-edit-section-meta">{{description}}</span>
    </div>
    <div class="local-dimensions-edit-section-fields">