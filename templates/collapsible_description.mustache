{{!
    @template local_dimensions/collapsible_description

    Reusable collapsible container for long descriptions or embedded media.

    Caps the visible height at 30% of the viewport (overridable via the
    --collapsible-max-vh CSS variable) and exposes an accessible toggle
    button. The local_dimensions/collapsible_description AMD module measures
    overflow and only shows the toggle when content exceeds the limit.

    Context variables required:
    * html (string) - The raw HTML content (already sanitized via format_text)
    * id (string) - Unique id used for aria-controls / aria-labelledby

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "html": "<p>A long description with embedded media...</p>",
        "id": "comp-42-desc"
    }
}}
<div class="local-dimensions-collapsible" data-collapsible-description>
    <div id="{{id}}-content"
         class="local-dimensions-collapsible-content"
         aria-hidden="false">
        {{{html}}}
    </div>
    <div class="local-dimensions-collapsible-fade" aria-hidden="true"></div>
    <button type="button"
            class="local-dimensions-collapsible-toggle"
            aria-expanded="false"
            aria-controls="{{id}}-content"
            data-label-show="{{#str}}show_more, local_dimensions{{/str}}"
            data-label-hide="{{#str}}show_less, local_dimensions{{/str}}"
            hidden>
        <span class="local-dimensions-collapsible-toggle-label">{{#str}}show_more, local_dimensions{{/str}}</span>
        <i class="fa fa-chevron-down" aria-hidden="true"></i>
    </button>
</div>
