{{!
    @template local_dimensions/edit_competency_rule_summary

    Native competency rule summary shown in the competency edit form.

    Context variables required:
    * status - Current rule status.
    * summary - Current rule summary.
    * detail - Additional explanatory text.
    * hasdetail - Whether detail should be displayed.
    * canconfigure - Whether the configure button should be displayed.
    * competencyid - Competency ID.

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "status": "No rule configured",
        "summary": "Configure a rule to automate completion.",
        "detail": "Learners can still be rated manually.",
        "hasdetail": true,
        "canconfigure": true,
        "competencyid": 42
    }
}}
<div class="local-dimensions-edit-rule-card" data-region="edit-rule-card">
    <div class="local-dimensions-edit-rule-copy">
        <span class="local-dimensions-edit-rule-status">{{status}}</span>
        <p class="local-dimensions-edit-rule-summary">{{summary}}</p>
        {{#hasdetail}}
        <p class="local-dimensions-edit-rule-detail">{{detail}}</p>
        {{/hasdetail}}
    </div>
    {{#canconfigure}}
    <button type="button" class="btn btn-secondary" data-action="open-rule-config" data-competency-id="{{competencyid}}">
        {{#str}}editcompetency_rule_configure, local_dimensions{{/str}}
    </button>
    {{/canconfigure}}
</div>