{{!
    @template local_dimensions/competency_tree_children

    Recursive partial for competency tree children.

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "children": [
            {
                "id": 2,
                "shortname": "Child competency",
                "idnumber": "COMP-B",
                "editurl": "/local/dimensions/edit_competency.php?id=2",
                "haschildren": false,
                "children": [],
                "depth": 1
            }
        ]
    }
}}
{{#children}}
<div class="local-dimensions-manage-tree-node" data-region="tree-node" data-depth="{{depth}}">
    <div class="local-dimensions-manage-tree-row" data-region="competency-row" data-competency-id="{{id}}" data-depth="{{depth}}" data-search="{{shortname}} {{idnumber}}" data-shortname="{{shortname}}" data-idnumber="{{idnumber}}" data-taxonomy="{{taxonomy}}" data-path="{{pathlabel}}" data-scale="{{scale}}" data-rule="{{rule}}" data-description="{{descriptionplain}}" data-coursecount="{{coursecount}}" data-edit-url="{{editurl}}" data-add-url="{{addchildurl}}" style="--local-dimensions-manage-indent: {{indent}}px">
        <button type="button" class="local-dimensions-manage-tree-toggle" data-action="toggle" aria-label="{{#str}}show_more, local_dimensions{{/str}}"{{^haschildren}} disabled{{/haschildren}}>
            <i class="fa fa-chevron-right" aria-hidden="true"></i>
        </button>
        <span class="local-dimensions-manage-taxonomy">{{taxonomy}}</span>
        <span class="local-dimensions-manage-tree-name">{{shortname}}</span>
        <span class="local-dimensions-manage-tree-id local-dimensions-manage-mono">{{idnumber}}</span>
        {{#hascourses}}<span class="local-dimensions-manage-chip">{{coursecount}} {{#str}}linkedcourses, tool_lp{{/str}}</span>{{/hascourses}}
        {{#hasrule}}<span class="local-dimensions-manage-chip local-dimensions-manage-chip-rule">{{#str}}competencyrule, tool_lp{{/str}}</span>{{/hasrule}}
        {{#canmanage}}
        <span class="local-dimensions-manage-tree-actions">
            <a class="btn btn-sm btn-secondary local-dimensions-manage-icon-action" href="{{editurl}}" aria-label="{{#str}}edit{{/str}}" title="{{#str}}edit{{/str}}"><i class="fa fa-pencil" aria-hidden="true"></i></a>
            <a class="btn btn-sm btn-secondary local-dimensions-manage-icon-action" href="{{addchildurl}}" aria-label="{{#str}}managecompetencies_addchild, local_dimensions{{/str}}" title="{{#str}}managecompetencies_addchild, local_dimensions{{/str}}"><i class="fa fa-plus" aria-hidden="true"></i></a>
            <button type="button" class="btn btn-sm btn-secondary local-dimensions-manage-icon-action" data-action="moveparent" data-id="{{id}}" aria-label="{{#str}}movetonewparent, tool_lp{{/str}}" title="{{#str}}movetonewparent, tool_lp{{/str}}"><i class="fa fa-arrows" aria-hidden="true"></i></button>
            <button type="button" class="btn btn-sm btn-secondary local-dimensions-manage-icon-action" data-action="relatedcompetencies" data-id="{{id}}" aria-label="{{#str}}addcrossreferencedcompetency, tool_lp{{/str}}" title="{{#str}}addcrossreferencedcompetency, tool_lp{{/str}}"><i class="fa fa-link" aria-hidden="true"></i></button>
            <button type="button" class="btn btn-sm btn-secondary local-dimensions-manage-icon-action" data-action="competencyrules" data-id="{{id}}" aria-label="{{#str}}competencyrule, tool_lp{{/str}}" title="{{#str}}competencyrule, tool_lp{{/str}}"><i class="fa fa-cog" aria-hidden="true"></i></button>
            <button type="button" class="btn btn-sm btn-secondary local-dimensions-manage-icon-action" data-action="moveup" data-id="{{id}}" aria-label="{{#str}}moveup{{/str}}" title="{{#str}}moveup{{/str}}"><i class="fa fa-arrow-up" aria-hidden="true"></i></button>
            <button type="button" class="btn btn-sm btn-secondary local-dimensions-manage-icon-action" data-action="movedown" data-id="{{id}}" aria-label="{{#str}}movedown{{/str}}" title="{{#str}}movedown{{/str}}"><i class="fa fa-arrow-down" aria-hidden="true"></i></button>
            <button type="button" class="btn btn-sm btn-danger local-dimensions-manage-icon-action" data-action="delete" data-id="{{id}}" data-name="{{shortname}}" aria-label="{{#str}}delete{{/str}}" title="{{#str}}delete{{/str}}"><i class="fa fa-trash" aria-hidden="true"></i></button>
        </span>
        {{/canmanage}}
    </div>
    {{#haschildren}}
    <div class="local-dimensions-manage-tree-children" data-region="tree-children">
        {{> local_dimensions/competency_tree_children}}
    </div>
    {{/haschildren}}
</div>
{{/children}}
