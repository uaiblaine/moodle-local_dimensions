{{!
    @template local_dimensions/view_competency

    Main template for the view competency page (Competency Tracker Mode).
    Renders the hero header and course grid based on context.

    Context variables required:
    * hascompetency (bool) - Whether a competency is selected
    * hascourses (bool) - Whether there are courses to display
    * hero (object) - Hero header data (title, description, hasdescription, bgcolor, hasbgcolor)
    * courses (array) - Array of course objects
    * hascustomcss (bool) - Whether there is custom CSS to inject
    * customcss (string) - Compiled CSS from competency SCSS custom field

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "hascompetency": true,
        "hascourses": true,
        "hero": {
            "title": "Communication Skills",
            "description": "<p>Description here</p>",
            "hasdescription": true,
            "bgcolor": "#3498db",
            "hasbgcolor": true
        },
        "courses": []
    }
}}
{{#hascustomcss}}
<textarea hidden id="local-dimensions-customcss-source-viewcompetency">{{customcss}}</textarea>
{{/hascustomcss}}
<div class="percentagemode-{{percentagemode}}">

{{#hascompetency}}
    {{#hero}}
        {{> local_dimensions/hero_header}}
    {{/hero}}
{{/hascompetency}}

{{#hascourses}}
    <div class="local-dimensions-filter-bar local-dimensions-toolbar">
        {{! Hidden until the batch completion call answers - the counts are unknowable before
            that, and a tab strip with blank numbers explains nothing. }}
        <div class="local-dimensions-filter-tabs" role="tablist" data-course-tabs
             aria-label="{{#str}}filter_courses, local_dimensions{{/str}}" hidden>
            <button class="local-dimensions-filter-tab" data-filter="incomplete" role="tab" aria-selected="false" type="button">
                {{#str}}filter_not_completed, local_dimensions{{/str}}
                <span class="local-dimensions-filter-count" data-count="incomplete"></span>
            </button>
            <button class="local-dimensions-filter-tab active" data-filter="all" role="tab" aria-selected="true" type="button">
                {{#str}}filter_all, local_dimensions{{/str}}
                <span class="local-dimensions-filter-count" data-count="all"></span>
            </button>
        </div>
        {{#haschipfilters}}
        {{#chipfilters}}
        <button type="button"
                class="local-dimensions-filter-toggle"
                data-filter-toggle
                aria-expanded="false"
                aria-controls="{{id}}">
            <i class="fa fa-filter" aria-hidden="true"></i>
            <span>{{#str}}filter_toggle, local_dimensions{{/str}}</span>
            <span class="local-dimensions-filter-toggle-count" data-chip-count hidden></span>
        </button>
        {{/chipfilters}}
        {{/haschipfilters}}
    </div>
{{/hascourses}}

{{#haschipfilters}}
    {{! Plain block toggled by the hidden attribute - see chip_filters.js initPanel. }}
    <div class="local-dimensions-filter-panel" data-filter-panel hidden>
        {{#chipfilters}}
            {{> local_dimensions/chip_filters }}
        {{/chipfilters}}
    </div>
{{/haschipfilters}}

{{#hascourses}}
    {{> local_dimensions/course_grid}}
{{/hascourses}}

{{^hascourses}}
    {{#hascompetency}}
        <div class="local-dimensions-empty" role="status">
            <span class="local-dimensions-empty-icon">
                <i class="fa fa-graduation-cap" aria-hidden="true"></i>
            </span>
            <span class="local-dimensions-empty-title">
                {{#str}}no_courses_linked, local_dimensions{{/str}}
            </span>
            <span class="local-dimensions-empty-text">
                {{#str}}no_courses_linked_note, local_dimensions{{/str}}
            </span>
        </div>
    {{/hascompetency}}
{{/hascourses}}

{{^hascompetency}}
    <div class="local-dimensions-empty" role="status">
        <span class="local-dimensions-empty-icon local-dimensions-empty-icon-warning">
            <i class="fa fa-exclamation-triangle" aria-hidden="true"></i>
        </span>
        <span class="local-dimensions-empty-title">
            {{#str}}competency_id_missing, local_dimensions{{/str}}
        </span>
        <span class="local-dimensions-empty-text">
            {{#str}}competency_id_missing_note, local_dimensions{{/str}}
        </span>
    </div>
{{/hascompetency}}

</div>
