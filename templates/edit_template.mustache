{{!
    @template local_dimensions/edit_template

    Edit learning plan template page shell.

    Context variables required:
    * heading (string) - Page heading (template short name).
    * contextname (string) - Owning context name (system or category).
    * hasidnumber (bool)
    * idnumber (string)
    * hidden (bool) - Whether the template is hidden.
    * hasduedate (bool)
    * duedateformatted (string)
    * returnurl (string)
    * formhtml (string) - Rendered Moodle form HTML.
    * sections (array) - {id, label, active}

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "heading": "Onboarding plan",
        "contextname": "System",
        "hasidnumber": true,
        "idnumber": "TPL-001",
        "hidden": false,
        "hasduedate": true,
        "duedateformatted": "31 Jan 2026",
        "returnurl": "https://example.com/local/dimensions/manage_templates.php",
        "sections": [
            {"id": "sec-basic", "label": "Basic", "active": true}
        ],
        "formhtml": "<form><div>Form fields</div></form>"
    }
}}
<div class="local-dimensions-edit" data-region="local-dimensions-edit-template">
    <a class="local-dimensions-edit-back" href="{{returnurl}}">{{#str}}edittemplate_back, local_dimensions{{/str}}</a>

    <header class="local-dimensions-edit-head">
        <div class="local-dimensions-edit-head-main">
            <div class="local-dimensions-edit-subtitle">{{contextname}}</div>
            <h1 class="local-dimensions-edit-title">{{heading}}</h1>
            <div class="local-dimensions-edit-meta">
                {{#hidden}}<span class="local-dimensions-edit-chip">{{#str}}hidden, tool_lp{{/str}}</span>{{/hidden}}
                {{#hasidnumber}}<code class="local-dimensions-edit-code">{{idnumber}}</code>{{/hasidnumber}}
                {{#hasduedate}}<span class="local-dimensions-edit-chip"><i class="fa fa-calendar" aria-hidden="true"></i> {{duedateformatted}}</span>{{/hasduedate}}
            </div>
        </div>
        <div class="local-dimensions-edit-actions">
            <a class="btn btn-secondary" href="{{returnurl}}">{{#str}}cancel{{/str}}</a>
            <button type="button" class="btn btn-primary" data-action="submit-edit-form">
                {{#str}}savechanges{{/str}}
            </button>
        </div>
    </header>

    <div class="local-dimensions-edit-grid">
        <nav class="local-dimensions-edit-nav" aria-label="{{#str}}edittemplate_sections_nav, local_dimensions{{/str}}">
            {{#sections}}
            <a href="#{{id}}" {{#active}}class="active" aria-current="page"{{/active}} data-section-link="{{id}}">{{label}}</a>
            {{/sections}}
        </nav>

        <div class="local-dimensions-edit-main">
            {{{formhtml}}}
        </div>
    </div>
</div>
