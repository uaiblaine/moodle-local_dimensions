{{!
    @template local_dimensions/view_plan_summary

    Full plan overview with competencies in accordion.
    Displays when view-plan.php is accessed with only plan ID.

    Context variables required:
    * planid (int) - Plan ID
    * percentagemode (string) - Percentage display mode (hover/inline)
    * hero (object) - Hero header data
    * subline_is_status / subline_is_rating / subline_is_text (bool) - Which accordion subline to render
    * hascompetencies (bool) - Whether there are competencies
    * competencies (array) - Array of competency objects with:
        - id, planorder, shortname, isproficient, rating, hasrating, isfavourite
        - badgeproficienticonurl, badgewarningiconurl
        - sublinetext, hassublinetext, filtervaluesjson
    * competencycount (int) - Total competencies
    * incompletecount (int) - Number of not-yet-proficient competencies
    * sortmode (string) - Stored sort: planorder, name, completed or favourites
    * sort_is_planorder / sort_is_name / sort_is_completed / sort_is_favourites (bool) - Which sort is checked
    * filter_is_incomplete / filter_is_all (bool) - Which completion tab starts active
    * viewmode (string) - Stored layout: list or grid
    * view_is_list / view_is_grid (bool) - Which layout starts active
    * showstar (bool) - Whether the learner owns this plan, so the favourites controls render
    * hasfavourites (bool) - Whether at least one is starred, so the favourites filter renders
    * favonly (bool) - Whether the favourites-only filter starts active
    * favouritesjson (string) - The whole stored favourites map, for the client to merge into
    * nonfavouritecount (int) - How many competencies are not favourited
    * haschipfilters, chipfilters - Chip-filter model
    * hascustomcss, customcss - Compiled template SCSS

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "planid": 10,
        "percentagemode": "hover",
        "hero": {
            "title": "Plan Hero",
            "description": "<p>Description</p>",
            "hasdescription": true,
            "hasbgcolor": true,
            "bgcolor": "#2c3e50",
            "hastextcolor": true,
            "textcolor": "#ffffff"
        },
        "hascompetencies": false,
        "competencies": [],
        "competencycount": 0,
        "incompletecount": 0,
        "sortmode": "planorder",
        "sort_is_planorder": true,
        "sort_is_name": false,
        "sort_is_completed": false,
        "sort_is_favourites": false,
        "filter_is_incomplete": true,
        "filter_is_all": false,
        "viewmode": "list",
        "view_is_list": true,
        "view_is_grid": false,
        "showstar": true,
        "hasfavourites": false,
        "favonly": false,
        "favouritesjson": "{}",
        "nonfavouritecount": 0
    }
}}
{{! Custom SCSS compiled CSS from template }}
{{#hascustomcss}}
<textarea hidden id="local-dimensions-customcss-source-summary">{{customcss}}</textarea>
{{/hascustomcss}}

{{! Hero header with plan/template info }}
{{#hero}}
{{> local_dimensions/hero_header}}
{{/hero}}

<div class="percentagemode-{{percentagemode}}">
    {{#hascompetencies}}
    <div class="local-dimensions-plan-summary mt-4"
         data-planid="{{planid}}"
         data-sortmode="{{sortmode}}"
         data-viewmode="{{viewmode}}"
         data-percentagemode="{{percentagemode}}"
         data-favourites="{{favouritesjson}}">

        {{! Toolbar: favourites, completion segment, search, sort, chip filter. The active tab,
            the checked sort and the favourites state come from the stored preference,
            resolved server-side. }}
        <div class="local-dimensions-filter-bar local-dimensions-toolbar">
            {{#showstar}}
            <button type="button"
                    class="local-dimensions-fav-toggle"
                    data-fav-toggle
                    aria-pressed="{{#favonly}}true{{/favonly}}{{^favonly}}false{{/favonly}}"
                    aria-label="{{#str}}fav_only, local_dimensions{{/str}}"
                    {{^hasfavourites}}hidden{{/hasfavourites}}>
                <i class="fa fa-star" aria-hidden="true"></i>
            </button>
            {{/showstar}}
            <div class="local-dimensions-filter-tabs" role="tablist" aria-label="{{#str}}filter_competencies, local_dimensions{{/str}}">
                <button class="local-dimensions-filter-tab {{#filter_is_incomplete}}active{{/filter_is_incomplete}}" data-filter="incomplete" role="tab" aria-selected="{{#filter_is_incomplete}}true{{/filter_is_incomplete}}{{^filter_is_incomplete}}false{{/filter_is_incomplete}}" type="button">
                    {{#str}}filter_not_completed, local_dimensions{{/str}}
                    <span class="local-dimensions-filter-count" data-count="incomplete">{{incompletecount}}</span>
                </button>
                <button class="local-dimensions-filter-tab {{#filter_is_all}}active{{/filter_is_all}}" data-filter="all" role="tab" aria-selected="{{#filter_is_all}}true{{/filter_is_all}}{{^filter_is_all}}false{{/filter_is_all}}" type="button">
                    {{#str}}filter_all, local_dimensions{{/str}}
                    <span class="local-dimensions-filter-count" data-count="all">{{competencycount}}</span>
                </button>
            </div>
            <div class="local-dimensions-search-wrapper">
                <i class="fa fa-search local-dimensions-search-icon" aria-hidden="true"></i>
                <input type="text"
                       id="local-dimensions-search-input"
                       class="local-dimensions-search-input"
                       placeholder="{{#str}}search_competencies, local_dimensions{{/str}}"
                       aria-label="{{#str}}search_competencies, local_dimensions{{/str}}"
                       autocomplete="off" />
                <button type="button" class="local-dimensions-search-clear" aria-label="{{#str}}clear, core{{/str}}" style="display:none;">
                    <i class="fa fa-times" aria-hidden="true"></i>
                </button>
            </div>
            {{! Same plain-block mechanism as the chip panel below: toggled by the hidden
                attribute, so no Bootstrap 4 vs 5 data attribute pair is involved. }}
            <div class="local-dimensions-sort">
                <button type="button"
                        class="local-dimensions-sort-toggle"
                        data-sort-toggle
                        aria-haspopup="true"
                        aria-expanded="false"
                        aria-controls="local-dimensions-viewplan-sort-menu"
                        aria-label="{{#str}}sort_label, local_dimensions{{/str}}">
                    <i class="fa fa-sort-amount-asc" aria-hidden="true"></i>
                </button>
                <div class="local-dimensions-sort-menu" id="local-dimensions-viewplan-sort-menu" role="menu" hidden>
                    <span class="local-dimensions-sort-heading">{{#str}}sort_by, local_dimensions{{/str}}</span>
                    <button type="button" role="menuitemradio" data-sort="planorder" aria-checked="{{#sort_is_planorder}}true{{/sort_is_planorder}}{{^sort_is_planorder}}false{{/sort_is_planorder}}">
                        <i class="fa fa-check" aria-hidden="true"></i>{{#str}}sort_planorder, local_dimensions{{/str}}
                    </button>
                    <button type="button" role="menuitemradio" data-sort="name" aria-checked="{{#sort_is_name}}true{{/sort_is_name}}{{^sort_is_name}}false{{/sort_is_name}}">
                        <i class="fa fa-check" aria-hidden="true"></i>{{#str}}sort_name, local_dimensions{{/str}}
                    </button>
                    <button type="button" role="menuitemradio" data-sort="completed" aria-checked="{{#sort_is_completed}}true{{/sort_is_completed}}{{^sort_is_completed}}false{{/sort_is_completed}}">
                        <i class="fa fa-check" aria-hidden="true"></i>{{#str}}sort_completedfirst, local_dimensions{{/str}}
                    </button>
                    {{#showstar}}
                    <button type="button" role="menuitemradio" data-sort="favourites" aria-checked="{{#sort_is_favourites}}true{{/sort_is_favourites}}{{^sort_is_favourites}}false{{/sort_is_favourites}}">
                        <i class="fa fa-check" aria-hidden="true"></i>{{#str}}sort_favourites, local_dimensions{{/str}}
                    </button>
                    {{/showstar}}
                </div>
            </div>
            {{#haschipfilters}}
            {{#chipfilters}}
            <button type="button"
                    class="local-dimensions-filter-toggle"
                    data-filter-toggle
                    aria-expanded="false"
                    aria-controls="{{id}}">
                <i class="fa fa-filter" aria-hidden="true"></i>
                <span>{{#str}}filter_toggle, local_dimensions{{/str}}</span>
                <span class="local-dimensions-filter-toggle-count" data-chip-count hidden></span>
            </button>
            {{/chipfilters}}
            {{/haschipfilters}}
            <div class="local-dimensions-view-toggle" role="group" aria-label="{{#str}}view_label, local_dimensions{{/str}}">
                <button type="button" data-view="list" aria-pressed="{{#view_is_list}}true{{/view_is_list}}{{^view_is_list}}false{{/view_is_list}}" aria-label="{{#str}}view_list, local_dimensions{{/str}}">
                    <i class="fa fa-list" aria-hidden="true"></i>
                </button>
                <button type="button" data-view="grid" aria-pressed="{{#view_is_grid}}true{{/view_is_grid}}{{^view_is_grid}}false{{/view_is_grid}}" aria-label="{{#str}}view_grid, local_dimensions{{/str}}">
                    <i class="fa fa-th-large" aria-hidden="true"></i>
                </button>
            </div>
        </div>

        {{#haschipfilters}}
            {{! Plain block toggled by the hidden attribute - not a Bootstrap collapse or
                dropdown, so no data-toggle/data-bs-toggle pair is needed for 4.5 vs 5.x.
                Must stay a plain block: .d-block and .d-flex are !important and would
                defeat [hidden]. }}
            <div class="local-dimensions-filter-panel" data-filter-panel hidden>
                {{#chipfilters}}
                    {{> local_dimensions/chip_filters }}
                {{/chipfilters}}
            </div>
        {{/haschipfilters}}

        {{! Competency accordion }}
        <div id="local-dimensions-viewplan-accordion"
             class="local-dimensions-competency-accordion {{#view_is_grid}}local-dimensions-grid-mode{{/view_is_grid}}"
             role="list"
             aria-label="{{#str}}plan_competencies, local_dimensions{{/str}}"
             aria-live="polite"
             aria-relevant="additions removals">
            {{#competencies}}
            <div class="local-dimensions-accordion-item {{#isproficient}}completed{{/isproficient}} {{#hasrating}}{{^isproficient}}rated{{/isproficient}}{{/hasrating}} {{#isfavourite}}local-dimensions-favourite{{/isfavourite}}"
                 role="listitem"
                 data-competency-id="{{id}}"
                 data-planorder="{{planorder}}"
                 data-filtervalues="{{filtervaluesjson}}">

                {{! Accordion content }}
                <div class="local-dimensions-accordion-wrapper flex-grow-1">
                    <div class="local-dimensions-accordion-head">
                    {{#showstar}}
                    <button type="button"
                            class="local-dimensions-star"
                            data-fav-star
                            data-competency-id="{{id}}"
                            aria-pressed="{{#isfavourite}}true{{/isfavourite}}{{^isfavourite}}false{{/isfavourite}}"
                            aria-label="{{#str}}fav_star, local_dimensions{{/str}}">
                        <i class="fa fa-star" aria-hidden="true"></i>
                    </button>
                    {{/showstar}}
                    <button class="local-dimensions-accordion-toggle"
                            type="button"
                            aria-expanded="false"
                            aria-controls="competency-content-{{id}}"
                            id="competency-header-{{id}}">
                        <div class="local-dimensions-accordion-header-content">
                            <span class="local-dimensions-accordion-title">{{shortname}}</span>
                            {{#subline_is_status}}
                                {{#hasrating}}
                                <span class="local-dimensions-grade-badge {{#isproficient}}badge-proficient{{/isproficient}}{{^isproficient}}badge-not-proficient{{/isproficient}}">
                                    {{#isproficient}}
                                    <img class="local-dimensions-grade-badge-icon" src="{{badgeproficienticonurl}}" alt="" aria-hidden="true">
                                    {{/isproficient}}
                                    {{^isproficient}}
                                    <img class="local-dimensions-grade-badge-icon" src="{{badgewarningiconurl}}" alt="" aria-hidden="true">
                                    {{/isproficient}}
                                    {{rating}}
                                </span>
                                {{/hasrating}}
                                {{^hasrating}}
                                <span class="local-dimensions-grade-badge badge-todo">
                                    {{#str}}todo, local_dimensions{{/str}}
                                </span>
                                {{/hasrating}}
                            {{/subline_is_status}}
                            {{#subline_is_rating}}
                                {{#hasrating}}
                                <span class="local-dimensions-grade-badge {{#isproficient}}badge-proficient{{/isproficient}}{{^isproficient}}badge-not-proficient{{/isproficient}}">
                                    {{rating}}
                                </span>
                                {{/hasrating}}
                            {{/subline_is_rating}}
                            {{#subline_is_text}}
                                {{#hassublinetext}}
                                <span class="local-dimensions-grade-badge badge-cfield">
                                    {{sublinetext}}
                                </span>
                                {{/hassublinetext}}
                            {{/subline_is_text}}
                        </div>
                        <i class="local-dimensions-accordion-icon fa fa-chevron-down" aria-hidden="true"></i>
                    </button>
                    </div>

                    <div class="local-dimensions-accordion-content"
                         id="competency-content-{{id}}"
                         aria-labelledby="competency-header-{{id}}"
                         hidden>
                        <div class="local-dimensions-accordion-body">
                            {{! Loading placeholder - content loaded via AJAX }}
                            <div class="local-dimensions-competency-summary-loading text-center py-3">
                                <div class="spinner-border spinner-border-sm text-primary" role="status">
                                    <span class="sr-only">{{#str}}loading_competency_summary, local_dimensions{{/str}}</span>
                                </div>
                                <span class="ml-2">{{#str}}loading_competency_summary, local_dimensions{{/str}}</span>
                            </div>
                            {{! AJAX loaded content will be inserted here }}
                            <div class="local-dimensions-competency-summary-content" style="display: none;"></div>
                            {{! Error message }}
                            <div class="local-dimensions-competency-summary-error alert alert-danger" style="display: none;">
                                {{#str}}error_loading_summary, local_dimensions{{/str}}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{/competencies}}
        </div>

        {{#showstar}}
        {{! Renders only while the favourites filter is on, so a learner cannot forget it is
            on and conclude the rest of the plan has vanished. Activating it clears the
            filter. Like the no-results block below, it must not carry
            local-dimensions-accordion-item, whose display is forced once the filter runs. }}
        <button type="button" class="local-dimensions-ghost" data-ghost hidden>
            <span class="local-dimensions-ghost-icon">
                <i class="fa fa-plus" aria-hidden="true"></i>
            </span>
            <span class="local-dimensions-ghost-body">
                <span class="local-dimensions-ghost-title" data-ghost-count>{{#str}}fav_ghost, local_dimensions, {{nonfavouritecount}}{{/str}}</span>
                <span class="local-dimensions-ghost-text">{{#str}}fav_ghost_note, local_dimensions{{/str}}</span>
            </span>
        </button>
        {{/showstar}}

        {{! Sits outside the role="list" region, and must not carry
            local-dimensions-accordion-item - the filter-initialized rules force those to
            display: block, which would fight the hidden attribute. }}
        <div id="local-dimensions-viewplan-noresults" class="local-dimensions-empty" role="status" hidden>
            <span class="local-dimensions-empty-icon">
                <i class="fa fa-search" aria-hidden="true"></i>
            </span>
            <span class="local-dimensions-empty-title">
                {{#str}}filter_noresults, local_dimensions{{/str}}
            </span>
            <span class="local-dimensions-empty-text">
                {{#str}}filter_noresults_note, local_dimensions{{/str}}
            </span>
            <button type="button" class="local-dimensions-empty-action" data-noresults-clear>
                {{#str}}filter_chip_clear, local_dimensions{{/str}}
            </button>
        </div>
    </div>
    {{/hascompetencies}}

    {{^hascompetencies}}
    <div class="local-dimensions-empty" role="status">
        <span class="local-dimensions-empty-icon">
            <i class="fa fa-list-ul" aria-hidden="true"></i>
        </span>
        <span class="local-dimensions-empty-title">
            {{#str}}no_competencies_in_plan, local_dimensions{{/str}}
        </span>
        <span class="local-dimensions-empty-text">
            {{#str}}no_competencies_in_plan_note, local_dimensions{{/str}}
        </span>
    </div>
    {{/hascompetencies}}
</div>
