{{!
    @template local_dimensions/view_plan_summary

    Full plan overview with competencies in accordion.
    Displays when view-plan.php is accessed with only plan ID.

    Context variables required:
    * hasplan (bool) - Whether we have a valid plan
    * planid (int) - Plan ID
    * userid (int) - User ID
    * planname (string) - Plan name
    * hero (object) - Hero header data
    * hascompetencies (bool) - Whether there are competencies
    * competencies (array) - Array of competency objects with:
        - id, shortname, isproficient, rating, hasrating
        - viewurl, index, isfirst, islast
    * competencycount (int) - Total competencies

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "hasplan": true,
        "planid": 10,
        "userid": 5,
        "planname": "Plan Example",
        "percentagemode": "hover",
        "hero": {
            "title": "Plan Hero",
            "description": "<p>Description</p>",
            "hasdescription": true,
            "hasbgcolor": true,
            "bgcolor": "#2c3e50",
            "hastextcolor": true,
            "textcolor": "#ffffff"
        },
        "hascompetencies": false,
        "competencies": [],
        "competencycount": 0,
        "incompletecount": 0
    }
}}
{{! Custom SCSS compiled CSS from template }}
{{#hascustomcss}}
<script type="text/plain" id="local-dimensions-customcss-source-summary">{{{customcss}}}</script>
{{/hascustomcss}}

{{! Hero header with plan/template info }}
{{#hero}}
{{> local_dimensions/hero_header}}
{{/hero}}

<div class="percentagemode-{{percentagemode}}">
    {{#hascompetencies}}
    <div class="local-dimensions-plan-summary mt-4"
         data-planid="{{planid}}">

        {{! Filter bar: tabs + search }}
        <div class="local-dimensions-filter-bar">
            <div class="local-dimensions-filter-tabs" role="tablist" aria-label="{{#str}}filter_competencies, local_dimensions{{/str}}">
                <button class="local-dimensions-filter-tab active" data-filter="incomplete" role="tab" aria-selected="true" type="button">
                    {{#str}}filter_not_completed, local_dimensions{{/str}}
                    <span class="local-dimensions-filter-count" data-count="incomplete">{{incompletecount}}</span>
                </button>
                <button class="local-dimensions-filter-tab" data-filter="all" role="tab" aria-selected="false" type="button">
                    {{#str}}filter_all, local_dimensions{{/str}}
                    <span class="local-dimensions-filter-count" data-count="all">{{competencycount}}</span>
                </button>
            </div>
            <div class="local-dimensions-search-wrapper">
                <i class="fa fa-search local-dimensions-search-icon" aria-hidden="true"></i>
                <input type="text"
                       id="local-dimensions-search-input"
                       class="local-dimensions-search-input"
                       placeholder="{{#str}}search_competencies, local_dimensions{{/str}}"
                       aria-label="{{#str}}search_competencies, local_dimensions{{/str}}"
                       autocomplete="off" />
                <button type="button" class="local-dimensions-search-clear" aria-label="{{#str}}clear, core{{/str}}" style="display:none;">
                    <i class="fa fa-times" aria-hidden="true"></i>
                </button>
            </div>
        </div>

        {{! Competency accordion }}
        <div class="local-dimensions-competency-accordion" role="list" aria-label="{{#str}}plan_competencies, local_dimensions{{/str}}">
            {{#competencies}}
            <div class="local-dimensions-accordion-item {{#isproficient}}completed{{/isproficient}} {{#hasrating}}{{^isproficient}}rated{{/isproficient}}{{/hasrating}}"
                 role="listitem"
                 data-competency-id="{{id}}">

                {{! Accordion content }}
                <div class="local-dimensions-accordion-wrapper flex-grow-1">
                    <button class="local-dimensions-accordion-toggle"
                            type="button"
                            aria-expanded="false"
                            aria-controls="competency-content-{{id}}"
                            id="competency-header-{{id}}">
                        <div class="local-dimensions-accordion-header-content">
                            <span class="local-dimensions-accordion-title">{{shortname}}</span>
                            {{#hasrating}}
                            <span class="local-dimensions-grade-badge {{#isproficient}}badge-proficient{{/isproficient}}{{^isproficient}}badge-not-proficient{{/isproficient}}">
                                {{#isproficient}}
                                <img class="local-dimensions-grade-badge-icon" src="{{badgeproficienticonurl}}" alt="" aria-hidden="true">
                                {{/isproficient}}
                                {{^isproficient}}
                                <img class="local-dimensions-grade-badge-icon" src="{{badgewarningiconurl}}" alt="" aria-hidden="true">
                                {{/isproficient}}
                                {{rating}}
                            </span>
                            {{/hasrating}}
                            {{^hasrating}}
                            <span class="local-dimensions-grade-badge badge-todo">
                                {{#str}}todo, local_dimensions{{/str}}
                            </span>
                            {{/hasrating}}
                        </div>
                        <i class="local-dimensions-accordion-icon fa fa-chevron-down" aria-hidden="true"></i>
                    </button>

                    <div class="local-dimensions-accordion-content"
                         id="competency-content-{{id}}"
                         aria-labelledby="competency-header-{{id}}"
                         hidden>
                        <div class="local-dimensions-accordion-body">
                            {{! Loading placeholder - content loaded via AJAX }}
                            <div class="local-dimensions-competency-summary-loading text-center py-3">
                                <div class="spinner-border spinner-border-sm text-primary" role="status">
                                    <span class="sr-only">{{#str}}loading_competency_summary, local_dimensions{{/str}}</span>
                                </div>
                                <span class="ml-2">{{#str}}loading_competency_summary, local_dimensions{{/str}}</span>
                            </div>
                            {{! AJAX loaded content will be inserted here }}
                            <div class="local-dimensions-competency-summary-content" style="display: none;"></div>
                            {{! Error message }}
                            <div class="local-dimensions-competency-summary-error alert alert-danger" style="display: none;">
                                {{#str}}error_loading_summary, local_dimensions{{/str}}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{/competencies}}
        </div>
    </div>
    {{/hascompetencies}}

    {{^hascompetencies}}
    <div class="alert alert-info mt-4">
        {{#str}}no_competencies_in_plan, local_dimensions{{/str}}
    </div>
    {{/hascompetencies}}
</div>
{{#js}}
(function() {
    var source = document.getElementById('local-dimensions-customcss-source-summary');
    if (!source || !source.textContent.trim()) {
        return;
    }
    var style = document.createElement('style');
    style.textContent = source.textContent;
    document.head.appendChild(style);
    source.remove();
})();
{{/js}}
