{{!
    @template local_dimensions/edit_competency

    Edit competency page shell.

    Context variables required:
    * heading - Page heading.
    * frameworkname - Competency framework name.
    * taxonomy - Current taxonomy label.
    * formhtml - Rendered Moodle form HTML.

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "heading": "Edit competency",
        "frameworkname": "Digital skills",
        "taxonomy": "Competency",
        "hasidnumber": true,
        "idnumber": "DIGI-001",
        "returnurl": "https://example.com/local/dimensions/manage_competencies.php",
        "competencymodeljson": "{}",
        "rulesmodulesjson": "[]",
        "sections": [
            {
                "id": "sec-basic",
                "label": "Basic",
                "active": true
            }
        ],
        "formhtml": "<form><div>Form fields</div></form>"
    }
}}
<div class="local-dimensions-edit" data-region="local-dimensions-edit">
    <script type="application/json" data-region="competency-model">{{{competencymodeljson}}}</script>
    <script type="application/json" data-region="rules-modules">{{{rulesmodulesjson}}}</script>

    <a class="local-dimensions-edit-back" href="{{returnurl}}">{{#str}}editcompetency_back, local_dimensions{{/str}}</a>

    <header class="local-dimensions-edit-head">
        <div class="local-dimensions-edit-head-main">
            <div class="local-dimensions-edit-subtitle">{{frameworkname}}</div>
            <h1 class="local-dimensions-edit-title">{{heading}}</h1>
            <div class="local-dimensions-edit-meta">
                {{#taxonomy}}<span class="local-dimensions-edit-chip">{{taxonomy}}</span>{{/taxonomy}}
                {{#hasidnumber}}<code class="local-dimensions-edit-code">{{idnumber}}</code>{{/hasidnumber}}
            </div>
        </div>
        <div class="local-dimensions-edit-actions">
            <a class="btn btn-secondary" href="{{returnurl}}">{{#str}}cancel{{/str}}</a>
            <button type="button" class="btn btn-primary" data-action="submit-edit-form">
                {{#str}}savechanges{{/str}}
            </button>
        </div>
    </header>

    <div class="local-dimensions-edit-grid">
        <nav class="local-dimensions-edit-nav" aria-label="{{#str}}editcompetency_sections_nav, local_dimensions{{/str}}">
            {{#sections}}
            <a href="#{{id}}" {{#active}}class="active"{{/active}} data-section-link="{{id}}">{{label}}</a>
            {{/sections}}
        </nav>

        <div class="local-dimensions-edit-main">
            {{{formhtml}}}
        </div>
    </div>
</div>
