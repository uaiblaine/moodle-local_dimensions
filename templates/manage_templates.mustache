{{!
    @template local_dimensions/manage_templates

    Manage learning plan templates page with context selector and template list.

    Context variables required:
    * contexttype (string) - Current context selector value (system|coursecat)
    * issystemcontext (bool)
    * iscoursecatcontext (bool)
    * needscategoryselection (bool) - True when coursecat is selected but no category picked yet
    * categoryoptions (array) - Course category options {id, name, selected, templatecount, hastemplates}
    * hascategoryoptions (bool)
    * selectedcategoryid (int)
    * selectedcategoryname (string)
    * selectedcontextname (string)
    * hastemplates (bool)
    * templates (array) - Template rows {id, shortname, idnumber, hasidnumber, description,
                                          descriptionplain, hasdescription, hidden,
                                          plancount, hasplans, cohortcount, hascohorts,
                                          duedate, duedateformatted, hasduedate,
                                          editurl, cohortsurl, plansurl, pagecontextid}
    * templatecount (int)
    * hashiddentemplates (bool)
    * showhidden (bool)
    * search (string)
    * view (string) - cards|table
    * viewcards (bool)
    * viewtable (bool)
    * canmanage (bool)
    * canaddtemplate (bool)
    * newtemplateurl (string)
    * nativetemplatesurl (string)
    * pagecontextid (int)

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="local-dimensions-manage" data-region="local-dimensions-manage-templates" data-view="{{view}}" data-page-context-id="{{pagecontextid}}" data-string-hidden="{{#str}}hidden, tool_lp{{/str}}">
    <script type="application/json" data-region="templates-model">{{{templatesjson}}}</script>
    <div class="local-dimensions-manage-header">
        <div>
            <div class="local-dimensions-manage-kicker">{{#str}}learningplantemplates, local_dimensions{{/str}}</div>
            <h2 class="local-dimensions-manage-title">{{#str}}managetemplates, local_dimensions{{/str}}</h2>
            <p class="local-dimensions-manage-subtitle">{{#str}}managetemplates_intro, local_dimensions{{/str}}</p>
        </div>
        <div class="local-dimensions-manage-header-actions">
            <a class="btn btn-secondary" href="{{nativetemplatesurl}}">{{#str}}learningplantemplates, local_dimensions{{/str}}</a>
            {{#canaddtemplate}}
            <a class="btn btn-primary" href="{{newtemplateurl}}"><i class="fa fa-plus" aria-hidden="true"></i>{{#str}}managetemplates_addtemplate, local_dimensions{{/str}}</a>
            {{/canaddtemplate}}
        </div>
    </div>

    <form method="get" class="local-dimensions-manage-toolbar" data-region="manage-form">
        <input type="hidden" name="contexttype" value="{{contexttype}}" data-region="context-type-input">
        <input type="hidden" name="view" value="{{view}}" data-region="view-input">
        <div class="local-dimensions-manage-toolbar-main">
            <div class="local-dimensions-manage-field local-dimensions-manage-context-field">
                <span>{{#str}}managetemplates_context, local_dimensions{{/str}}</span>
                <div class="local-dimensions-manage-segmented local-dimensions-manage-context-switch" role="group" aria-label="{{#str}}managetemplates_context, local_dimensions{{/str}}">
                    <button type="button" class="local-dimensions-manage-segment {{#issystemcontext}}active{{/issystemcontext}}" data-action="context" data-context-type="system">
                        <i class="fa fa-globe" aria-hidden="true"></i>
                        <span>{{#str}}managetemplates_context_system, local_dimensions{{/str}}</span>
                    </button>
                    <button type="button" class="local-dimensions-manage-segment {{#iscoursecatcontext}}active{{/iscoursecatcontext}}" data-action="context" data-context-type="coursecat">
                        <i class="fa fa-folder-open" aria-hidden="true"></i>
                        <span>{{#str}}managetemplates_context_coursecat, local_dimensions{{/str}}</span>
                    </button>
                </div>
            </div>
            {{#iscoursecatcontext}}
            <label class="local-dimensions-manage-field local-dimensions-manage-category-field" for="categoryid">
                <span>{{#str}}managetemplates_category, local_dimensions{{/str}}</span>
                <select name="categoryid" id="categoryid" class="form-control" data-region="category-select" data-placeholder="{{#str}}managetemplates_category_placeholder, local_dimensions{{/str}}" data-no-selection="{{#str}}managetemplates_category_noselection, local_dimensions{{/str}}">
                    <option value="0">{{#str}}managetemplates_category_placeholder, local_dimensions{{/str}}</option>
                    {{#categoryoptions}}
                    <option value="{{id}}"{{#selected}} selected{{/selected}} data-templatecount="{{templatecount}}">{{name}}</option>
                    {{/categoryoptions}}
                </select>
            </label>
            {{/iscoursecatcontext}}
            {{#hashiddentemplates}}
            <label class="local-dimensions-manage-check">
                <input type="checkbox" name="showhidden" value="1" data-region="show-hidden-templates"{{#showhidden}} checked{{/showhidden}}>
                <span>{{#str}}managetemplates_showhidden, local_dimensions{{/str}}</span>
            </label>
            {{/hashiddentemplates}}
        </div>

        <div class="local-dimensions-manage-toolbar-tools">
            <label class="local-dimensions-manage-search" for="local-dimensions-template-search">
                <span class="sr-only">{{#str}}managetemplates_searchplaceholder, local_dimensions{{/str}}</span>
                <i class="fa fa-search" aria-hidden="true"></i>
                <input id="local-dimensions-template-search" type="search" name="search" value="{{search}}" placeholder="{{#str}}managetemplates_searchplaceholder, local_dimensions{{/str}}" data-region="template-search">
            </label>
            <div class="local-dimensions-manage-segmented" role="group" aria-label="{{#str}}managetemplates_layout, local_dimensions{{/str}}">
                <button type="button" class="local-dimensions-manage-segment {{#viewcards}}active{{/viewcards}}" data-action="view" data-view="cards">
                    <i class="fa fa-th-large" aria-hidden="true"></i>
                    <span>{{#str}}managetemplates_cards, local_dimensions{{/str}}</span>
                </button>
                <button type="button" class="local-dimensions-manage-segment {{#viewtable}}active{{/viewtable}}" data-action="view" data-view="table">
                    <i class="fa fa-table" aria-hidden="true"></i>
                    <span>{{#str}}managetemplates_table, local_dimensions{{/str}}</span>
                </button>
            </div>
            <label class="local-dimensions-manage-check">
                <input type="checkbox" data-region="show-ids" checked>
                <span>{{#str}}managetemplates_showids, local_dimensions{{/str}}</span>
            </label>
        </div>
    </form>

    {{^needscategoryselection}}
    {{#hastemplates}}
    <div class="local-dimensions-manage-body local-dimensions-manage-body-templates">
        <section class="local-dimensions-manage-templates-pane" data-region="templates-pane">
            {{#viewcards}}
            <div class="local-dimensions-template-cards-grid" data-region="templates-cards">
                {{#templates}}
                {{> local_dimensions/template_card }}
                {{/templates}}
            </div>
            {{/viewcards}}

            {{#viewtable}}
            <div class="local-dimensions-manage-table-wrap local-dimensions-manage-templates-table-wrap">
                <table class="generaltable local-dimensions-manage-table local-dimensions-manage-templates-table">
                    <thead>
                        <tr>
                            <th scope="col">{{#str}}name{{/str}}</th>
                            <th scope="col">{{#str}}idnumber{{/str}}</th>
                            <th scope="col">{{#str}}status{{/str}}</th>
                            <th scope="col">{{#str}}managetemplates_plans, local_dimensions{{/str}}</th>
                            <th scope="col">{{#str}}managetemplates_cohorts, local_dimensions{{/str}}</th>
                            <th scope="col">{{#str}}managetemplates_duedate, local_dimensions{{/str}}</th>
                            <th scope="col" class="local-dimensions-manage-actions-col">{{#str}}actions{{/str}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#templates}}
                        <tr class="local-dimensions-manage-table-row" data-region="template-row" data-template-id="{{id}}" data-search="{{shortname}} {{idnumber}}">
                            <td><strong>{{shortname}}</strong>{{#hasdescription}}<div class="text-muted small">{{descriptionplain}}</div>{{/hasdescription}}</td>
                            <td class="local-dimensions-manage-id-cell">{{#hasidnumber}}<span class="local-dimensions-manage-mono">{{idnumber}}</span>{{/hasidnumber}}</td>
                            <td>{{#hidden}}<span class="local-dimensions-manage-chip">{{#str}}hidden, tool_lp{{/str}}</span>{{/hidden}}{{^hidden}}<span class="text-muted">{{#str}}visible{{/str}}</span>{{/hidden}}</td>
                            <td>{{plancount}}</td>
                            <td>{{cohortcount}}</td>
                            <td>{{#hasduedate}}{{duedateformatted}}{{/hasduedate}}{{^hasduedate}}<span class="text-muted">{{#str}}managetemplates_duedate_none, local_dimensions{{/str}}</span>{{/hasduedate}}</td>
                            <td class="local-dimensions-manage-row-actions">
                                <a class="btn btn-sm btn-secondary" href="{{cohortsurl}}" title="{{#str}}managetemplates_cohorts_action, local_dimensions{{/str}}" aria-label="{{#str}}managetemplates_cohorts_action, local_dimensions{{/str}}"><i class="fa fa-users" aria-hidden="true"></i></a>
                                <a class="btn btn-sm btn-secondary" href="{{plansurl}}" title="{{#str}}managetemplates_plans_action, local_dimensions{{/str}}" aria-label="{{#str}}managetemplates_plans_action, local_dimensions{{/str}}"><i class="fa fa-graduation-cap" aria-hidden="true"></i></a>
                                <a class="btn btn-sm btn-primary" href="{{editurl}}" title="{{#str}}edit{{/str}}" aria-label="{{#str}}edit{{/str}}"><i class="fa fa-pencil" aria-hidden="true"></i></a>
                            </td>
                        </tr>
                        {{/templates}}
                    </tbody>
                </table>
            </div>
            {{/viewtable}}
        </section>

        <div class="local-dimensions-details-resizer" data-region="details-resizer" role="separator" aria-orientation="vertical" aria-label="{{#str}}managetemplates_details, local_dimensions{{/str}}" tabindex="0"></div>

        <aside class="local-dimensions-details" data-region="details-pane">
            <div data-region="details-empty">
                <div class="local-dimensions-details-empty-icon"><i class="fa fa-info-circle" aria-hidden="true"></i></div>
                <h3>{{#str}}managetemplates_details, local_dimensions{{/str}}</h3>
                <p>{{#str}}managetemplates_selectdetails, local_dimensions{{/str}}</p>
            </div>
            <div data-region="details-content" hidden>
                <div class="local-dimensions-manage-kicker" data-region="details-kicker">{{#str}}learningplantemplates, local_dimensions{{/str}}</div>
                <h3 data-region="details-title"></h3>
                <div class="local-dimensions-manage-mono" data-region="details-idnumber"></div>
                <div class="local-dimensions-details-chips" data-region="details-chips"></div>
                <dl class="local-dimensions-details-list">
                    <dt>{{#str}}managetemplates_duedate, local_dimensions{{/str}}</dt>
                    <dd data-region="details-duedate"></dd>
                    <dt>{{#str}}managetemplates_plans, local_dimensions{{/str}}</dt>
                    <dd data-region="details-plans"></dd>
                    <dt>{{#str}}managetemplates_cohorts, local_dimensions{{/str}}</dt>
                    <dd data-region="details-cohorts"></dd>
                    <dt>{{#str}}description{{/str}}</dt>
                    <dd data-region="details-description"></dd>
                </dl>
                <div class="local-dimensions-details-actions">
                    <a class="btn btn-primary" data-region="details-edit" href="#"><i class="fa fa-pencil" aria-hidden="true"></i> {{#str}}edit{{/str}}</a>
                    <a class="btn btn-secondary" data-region="details-cohorts-action" href="#"><i class="fa fa-users" aria-hidden="true"></i> {{#str}}managetemplates_cohorts_action, local_dimensions{{/str}}</a>
                    <a class="btn btn-secondary" data-region="details-plans-action" href="#"><i class="fa fa-graduation-cap" aria-hidden="true"></i> {{#str}}managetemplates_plans_action, local_dimensions{{/str}}</a>
                    {{#canmanage}}
                    <button type="button" class="btn btn-secondary" data-action="duplicate" data-region="details-duplicate" data-id="0"><i class="fa fa-copy" aria-hidden="true"></i> {{#str}}managetemplates_duplicate, local_dimensions{{/str}}</button>
                    <button type="button" class="btn btn-danger" data-action="delete" data-region="details-delete" data-id="0" data-name=""><i class="fa fa-trash" aria-hidden="true"></i> {{#str}}managetemplates_delete, local_dimensions{{/str}}</button>
                    {{/canmanage}}
                </div>
            </div>
        </aside>
    </div>
    <div class="local-dimensions-manage-no-results" data-region="no-results" hidden>{{#str}}managetemplates_emptysearch, local_dimensions{{/str}}</div>
    {{/hastemplates}}

    {{^hastemplates}}
    <div class="local-dimensions-manage-empty-state">
        {{#search}}
        <h3>{{#str}}managetemplates_emptysearch, local_dimensions{{/str}}</h3>
        {{/search}}
        {{^search}}
        <h3>{{#str}}managetemplates_emptycategory_title, local_dimensions{{/str}}</h3>
        <p>{{#str}}managetemplates_emptycategory_help, local_dimensions, {{selectedcontextname}}{{/str}}</p>
        {{#noaddpermission}}<p class="text-muted local-dimensions-manage-empty-hint">{{#str}}managetemplates_emptycategory_nopermission, local_dimensions{{/str}}</p>{{/noaddpermission}}
        {{#canaddtemplate}}
        <div class="local-dimensions-manage-empty-actions">
            <a class="btn btn-primary" href="{{newtemplateurl}}"><i class="fa fa-plus" aria-hidden="true"></i>{{#str}}managetemplates_addtemplate, local_dimensions{{/str}}</a>
        </div>
        {{/canaddtemplate}}
        {{/search}}
    </div>
    {{/hastemplates}}
    {{/needscategoryselection}}

    {{#needscategoryselection}}
    <div class="local-dimensions-manage-empty-state">
        <h3>{{#str}}managetemplates_selectcategory_title, local_dimensions{{/str}}</h3>
        <p>{{#str}}managetemplates_selectcategory_help, local_dimensions{{/str}}</p>
    </div>
    {{/needscategoryselection}}
</div>
