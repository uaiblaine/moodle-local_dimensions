{{!
    @template local_dimensions/progress_card_body

    Progress timeline component for course cards.
    Shows section completion status with visual indicators.

    Context variables required:
    * enabled (bool) - Whether completion tracking is enabled
    * locked (bool) - Whether the course is locked for the user
    * formatted_start_date (string) - When the course becomes available
    * is_enrolment_start (bool) - Whether the date is an enrolment start date
    * islearnmore (bool) - Whether to show "Learn More" button instead of "Locked Content"
    * showlockeddate (bool) - Whether to show the availability date
    * customicon (string) - CSS class for custom locked icon (empty = default lock icon from pix)
    * lockiconurl (string) - URL do fallback do cadeado
    * checkiconurl (string) - URL do ícone de concluído
    * circleiconurl (string) - URL do ícone neutro com atividades
    * infoiconurl (string) - URL do ícone de informação sem rastreamento
    * courseurl (string) - URL to the course page (for "Learn More" button)
    * learnmorebuttoncolor (string) - Hex color for the "Learn More" button background
    * sections (array) - Array of section objects with progress data

    @copyright  2026 Anderson Blaine
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "enabled": true,
        "locked": false,
        "formatted_start_date": "01/02/2026",
        "is_enrolment_start": false,
        "islearnmore": false,
        "showlockeddate": true,
        "customicon": "",
        "courseurl": "/course/view.php?id=42",
        "lockiconurl": "/local/dimensions/pix/status/lock.svg",
        "checkiconurl": "/local/dimensions/pix/status/check.svg",
        "circleiconurl": "/local/dimensions/pix/status/circle.svg",
        "infoiconurl": "/local/dimensions/pix/status/info.svg",
        "sections": [
            {
                "name": "Section 1",
                "percentage": 100,
                "has_activities": true,
                "url": "/course/section.php?id=1",
                "is_completed": true,
                "is_started": false,
                "locked": false
            }
        ]
    }
}}
<div style="position: relative; height: 100%;">
    {{#locked}}
    <div class="local-dimensions-locked-overlay">
        {{! Icon: custom FA icon or default lock SVG }}
        <div class="local-dimensions-locked-icon">
            {{#customicon}}
                <i class="{{customicon}}" aria-hidden="true"></i>
            {{/customicon}}
            {{^customicon}}
                <img class="local-dimensions-icon local-dimensions-icon-lock local-dimensions-locked-icon-image" src="{{lockiconurl}}" alt="" aria-hidden="true">
            {{/customicon}}
        </div>
        {{! Message: "Learn More" button or "Locked Content" text }}
        {{#islearnmore}}
            <a href="{{courseurl}}" class="local-dimensions-learnmore-btn" style="background: {{learnmorebuttoncolor}};">{{#str}}learn_more, local_dimensions{{/str}}</a>
        {{/islearnmore}}
        {{^islearnmore}}
            <div class="local-dimensions-locked-message">{{#str}}locked_content, local_dimensions{{/str}}</div>
        {{/islearnmore}}
        {{! Date: conditionally shown based on showlockeddate setting }}
        {{#showlockeddate}}
            <div class="local-dimensions-locked-date">
                {{#is_enrolment_start}}
                    {{#str}}enrolment_starts, local_dimensions, {{formatted_start_date}}{{/str}}
                {{/is_enrolment_start}}
                {{^is_enrolment_start}}
                    {{#str}}available_at, local_dimensions, {{formatted_start_date}}{{/str}}
                {{/is_enrolment_start}}
            </div>
        {{/showlockeddate}}
    </div>
    {{/locked}}

    {{^enabled}}
        <div class="p-3 text-muted text-center small">
            {{#str}}completion_disabled, local_dimensions{{/str}}
        </div>
    {{/enabled}}

    {{#enabled}}
    <div class="local-dimensions-timeline">
        {{#sections}}
        <div class="local-dimensions-timeline-item {{#is_completed}}completed{{/is_completed}} {{#is_started}}started{{/is_started}} {{#locked}}locked{{/locked}}">
            <div class="local-dimensions-timeline-marker">
                {{! Priority order: locked > is_completed > is_started > empty/info }}
                {{#locked}}
                    <img class="local-dimensions-icon local-dimensions-icon-lock-sm" src="{{lockiconurl}}" alt="" aria-hidden="true">
                {{/locked}}

                {{^locked}}
                    {{#is_completed}}
                        <img class="local-dimensions-icon local-dimensions-icon-check" src="{{checkiconurl}}" alt="" aria-hidden="true">
                    {{/is_completed}}

                    {{^is_completed}}
                        {{#is_started}}
                             <div class="local-dimensions-progress-ring-container" role="progressbar" aria-valuenow="{{percentage}}" aria-valuemin="0" aria-valuemax="100" aria-label="{{#str}}aria_completion_percentage, local_dimensions, {{percentage}}{{/str}}">
                                <svg class="local-dimensions-progress-ring" width="32" height="32" viewBox="0 0 32 32" aria-hidden="true">
                                   <!-- Background circle (gray) -->
                                   <circle class="local-dimensions-progress-ring__bg" cx="16" cy="16" r="12" />
                                   <!-- Progress circle (green) -->
                                   <circle class="local-dimensions-progress-ring__progress" cx="16" cy="16" r="12"
                                   style="stroke-dasharray: {{dasharray}} 75.4; stroke-dashoffset: 0;" />
                                </svg>
                                <span class="local-dimensions-progress-text" aria-hidden="true">{{percentage}}</span>
                            </div>
                        {{/is_started}}

                        {{^is_started}}
                            {{#has_activities}}
                                <img class="local-dimensions-icon local-dimensions-icon-circle" src="{{circleiconurl}}" alt="" aria-hidden="true">
                            {{/has_activities}}
                            {{^has_activities}}
                                <img class="local-dimensions-icon local-dimensions-icon-info" src="{{infoiconurl}}" alt="" aria-hidden="true" title="{{#str}}no_completion_tracking, local_dimensions{{/str}}">
                            {{/has_activities}}
                        {{/is_started}}
                    {{/is_completed}}
                {{/locked}}
            </div>

            <div class="local-dimensions-timeline-content">
                {{#locked}}
                    {{#url}}
                        <a href="{{url}}" class="text-muted" aria-label="{{#str}}view_section, local_dimensions, {{name}}{{/str}}">{{name}}</a>
                    {{/url}}
                    {{^url}}
                        <span class="text-muted">{{name}}</span>
                    {{/url}}
                {{/locked}}

                {{^locked}}
                    {{#url}}
                    <a href="{{url}}" aria-label="{{#str}}view_section, local_dimensions, {{name}}{{/str}}">{{name}}</a>
                    {{/url}}
                    {{^url}}
                    <span>{{name}}</span>
                    {{/url}}
                {{/locked}}
            </div>
        </div>
        {{/sections}}
    </div>
    {{/enabled}}

    {{#error}}
     <div class="alert alert-danger m-2">{{error}}</div>
    {{/error}}
</div>
